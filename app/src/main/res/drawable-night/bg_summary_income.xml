<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#064E3B"
                android:centerColor="#065F46"
                android:endColor="#059669"
                android:angle="135"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>
    <!-- Top-right glow orb -->
    <item android:left="100dp" android:bottom="60dp" android:right="-20dp" android:top="-20dp">
        <shape android:shape="oval">
            <solid android:color="#2034D399"/>
        </shape>
    </item>
    <!-- Gloss top strip -->
    <item android:bottom="90dp">
        <shape android:shape="rectangle">
            <gradient android:startColor="#1AFFFFFF" android:endColor="#00FFFFFF" android:angle="270"/>
            <corners android:topLeftRadius="24dp" android:topRightRadius="24dp"/>
        </shape>
    </item>
    <!-- Bottom shimmer -->
    <item android:top="90dp">
        <shape android:shape="rectangle">
            <gradient android:startColor="#00000000" android:endColor="#1000D4FF" android:angle="270"/>
            <corners android:bottomLeftRadius="24dp" android:bottomRightRadius="24dp"/>
        </shape>
    </item>
    <!-- Subtle hairline border, added on top of existing gradient -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#33FFFFFF"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>
</layer-list>
