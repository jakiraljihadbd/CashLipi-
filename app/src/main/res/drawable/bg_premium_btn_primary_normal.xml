<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/bkPrimary"
                android:endColor="@color/bkPrimaryDark"
                android:angle="135"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
    <!-- soft top light highlight for 3D depth -->
    <item android:top="0dp" android:left="2dp" android:right="2dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/bkTopHighlight"
                android:endColor="@color/transparent"
                android:angle="90"
                android:type="linear"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
</layer-list>
