<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/bkPrimaryDark"
                android:endColor="@color/bkPrimaryDark"
                android:angle="135"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bkPressedOverlay"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
</layer-list>
