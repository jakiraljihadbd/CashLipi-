<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="#1AE2136E"/>
            <corners android:radius="16dp"/>
            <stroke android:width="2dp" android:color="@color/bkashPink"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/dialogFieldBg"/>
            <corners android:radius="16dp"/>
            <stroke android:width="1.5dp" android:color="@color/dialogFieldBorder"/>
        </shape>
    </item>
</selector>
