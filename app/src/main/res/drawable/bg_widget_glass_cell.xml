<?xml version="1.0" encoding="utf-8"?>
<!-- opaque সলিড কালার — translucent-over-translucent স্ট্যাকিং এড়ানো হয়েছে (কালো রেন্ডার বাগ ফিক্স) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#262B52"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent"/>
            <stroke android:width="1dp" android:color="#3A3F63"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>

</layer-list>
