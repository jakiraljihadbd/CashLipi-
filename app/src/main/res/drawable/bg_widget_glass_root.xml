<?xml version="1.0" encoding="utf-8"?>
<!--
    আগে এখানে ৩-লেয়ারের gradient + translucent "glass" ইফেক্ট ছিল, যেটা অনেক
    OEM লঞ্চারে (Xiaomi/Realme/Oppo/Samsung ইত্যাদি) RemoteViews-এ ঠিকমতো
    কম্পোজিট না হয়ে পুরো উইজেট কালো দেখাচ্ছিল। এখন শুধু opaque (স্বচ্ছতাহীন)
    সলিড রঙ + পাতলা বর্ডার — নিরাপদ, সব ডিভাইসে একইরকম দেখাবে।
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1B1F3B"/>
            <corners android:radius="26dp"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent"/>
            <stroke android:width="1dp" android:color="#3A3F63"/>
            <corners android:radius="26dp"/>
        </shape>
    </item>

</layer-list>
