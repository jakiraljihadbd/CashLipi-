<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/bkTopHighlight">
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="@color/white"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
    <item>
        <selector>
            <item android:state_pressed="true" android:drawable="@drawable/bg_premium_btn_primary_pressed"/>
            <item android:drawable="@drawable/bg_premium_btn_primary_normal"/>
        </selector>
    </item>
</ripple>
