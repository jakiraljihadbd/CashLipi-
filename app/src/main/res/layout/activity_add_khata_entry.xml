<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgColor">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:paddingBottom="24dp"
        android:clipToPadding="false">

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_header_ledger"
                android:orientation="vertical"
                android:paddingTop="12dp" android:paddingBottom="22dp"
                android:paddingHorizontal="16dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text=" দেনা / পাওনা যোগ"
                        android:textSize="18sp" android:textStyle="bold" android:textColor="@color/white"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="দেনা বা পাওনার তথ্য লিখুন"
                    android:textSize="12sp" android:textColor="@color/white"/>
            </LinearLayout>

            <!-- Form Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="18dp" app:cardElevation="4dp"
                app:cardBackgroundColor="@color/cardBg">

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <!-- Type Toggle: Dena / Pabona -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ধরন নির্বাচন করুন"
                        android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/textPrimary" android:layout_marginBottom="8dp"/>

                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal" android:layout_marginBottom="16dp">

                        <Button android:id="@+id/btnTypeDena"
                            android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:layout_marginEnd="6dp"
                            android:text=" দেনা (আমি দেব)"
                            android:textSize="13sp" android:textStyle="bold"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:background="@drawable/bg_type_active_dena"/>

                        <Button android:id="@+id/btnTypePabona"
                            android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:layout_marginStart="6dp"
                            android:text=" পাওনা (আমি পাব)"
                            android:textSize="13sp" android:textStyle="bold"
                            android:textAllCaps="false"
                            android:textColor="@color/pabonaColor"
                            android:background="@drawable/bg_type_inactive_pabona"/>
                    </LinearLayout>

                    <!-- KhataCustomer Name -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text=" ব্যক্তির নাম"
                        android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/textPrimary" android:layout_marginBottom="6dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilKhataCustomer"
                        style="@style/AppTextInput"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="যার সাথে লেনদেন"
                        android:layout_marginBottom="14dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etKhataCustomer"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="textCapWords" android:imeOptions="actionNext"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Category / Reason -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text=" কারণ (ঐচ্ছিক)"
                        android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/textPrimary" android:layout_marginBottom="6dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilCategory"
                        style="@style/AppTextInput"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="লেনদেনের কারণ লিখুন"
                        android:layout_marginBottom="14dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCategory"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="textCapSentences" android:imeOptions="actionNext"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Amount -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text=" পরিমাণ (৳)"
                        android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/textPrimary" android:layout_marginBottom="6dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilAmount"
                        style="@style/AppTextInput"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="পরিমাণ লিখুন" android:layout_marginBottom="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etAmount"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textSize="18sp" android:textStyle="bold"
                            android:textColor="@color/ledgerColor"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Quick Amounts -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <Button android:id="@+id/btn50" style="@style/QuickAmountBtn"
                            android:layout_width="0dp" android:layout_height="@dimen/quick_btn_height"
                            android:layout_weight="1" android:text="৫" android:layout_marginEnd="4dp"/>
                        <Button android:id="@+id/btn100" style="@style/QuickAmountBtn"
                            android:layout_width="0dp" android:layout_height="@dimen/quick_btn_height"
                            android:layout_weight="1" android:text="১০" android:layout_marginEnd="4dp"/>
                        <Button android:id="@+id/btn500" style="@style/QuickAmountBtn"
                            android:layout_width="0dp" android:layout_height="@dimen/quick_btn_height"
                            android:layout_weight="1" android:text="২০" android:layout_marginEnd="4dp"/>
                        <Button android:id="@+id/btn1000" style="@style/QuickAmountBtn"
                            android:layout_width="0dp" android:layout_height="@dimen/quick_btn_height"
                            android:layout_weight="1" android:text="৫০"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="14dp">
                        <Button android:id="@+id/btn2000" style="@style/QuickAmountBtn"
                            android:layout_width="0dp" android:layout_height="@dimen/quick_btn_height"
                            android:layout_weight="1" android:text="১০০" android:layout_marginEnd="4dp"/>
                        <Button android:id="@+id/btn5000" style="@style/QuickAmountBtn"
                            android:layout_width="0dp" android:layout_height="@dimen/quick_btn_height"
                            android:layout_weight="1" android:text="২০০" android:layout_marginEnd="4dp"/>
                        <Button android:id="@+id/btn10000" style="@style/QuickAmountBtn"
                            android:layout_width="0dp" android:layout_height="@dimen/quick_btn_height"
                            android:layout_weight="1" android:text="৫০০" android:layout_marginEnd="4dp"/>
                        <Button android:id="@+id/btn20000" style="@style/QuickAmountBtn"
                            android:layout_width="0dp" android:layout_height="@dimen/quick_btn_height"
                            android:layout_weight="1" android:text="১০০০"/>
                    </LinearLayout>

                    <!-- Date & Time -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="14dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:layout_marginEnd="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text=" তারিখ" android:textSize="13sp" android:textStyle="bold"
                                android:textColor="@color/textPrimary" android:layout_marginBottom="6dp"/>
                            <TextView android:id="@+id/tvDate"
                                android:layout_width="match_parent" android:layout_height="48dp"
                                android:gravity="center_vertical" android:paddingHorizontal="12dp"
                                android:background="@drawable/bg_card_white"
                                android:textSize="13sp" android:textColor="@color/textPrimary"
                                android:clickable="true" android:focusable="true"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:layout_marginStart="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text=" সময়" android:textSize="13sp" android:textStyle="bold"
                                android:textColor="@color/textPrimary" android:layout_marginBottom="6dp"/>
                            <TextView android:id="@+id/tvTime"
                                android:layout_width="match_parent" android:layout_height="48dp"
                                android:gravity="center_vertical" android:paddingHorizontal="12dp"
                                android:background="@drawable/bg_card_white"
                                android:textSize="13sp" android:textColor="@color/textPrimary"
                                android:clickable="true" android:focusable="true"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Note -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilNote"
                        style="@style/AppTextInput"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint=" নোট (ঐচ্ছিক)"
                        android:layout_marginBottom="18dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNote"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="textMultiLine" android:minLines="2"
                            android:gravity="top"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button android:id="@+id/btnSaveKhataEntry"
                        style="@style/SubmitButton.KhataEntry"
                        android:layout_width="match_parent" android:layout_height="@dimen/btn_height"
                        android:text=" লেনদেন সংরক্ষণ করুন"
                        android:textColor="@color/white"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Recent KhataEntry Preview -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp" android:layout_marginTop="14dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="18dp" app:cardElevation="3dp"
                app:cardBackgroundColor="@color/cardBg">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text=" সর্বশেষ দেনা/পাওনা"
                            android:textSize="13sp" android:textStyle="bold"
                            android:textColor="@color/textPrimary"/>
                        <TextView android:id="@+id/tvViewAllKhataEntry"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="সব দেখুন →"
                            android:textSize="12sp" android:textColor="@color/ledgerColor"
                            android:clickable="true" android:focusable="true"/>
                    </LinearLayout>
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvRecentKhataEntry"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"/>
                    <LinearLayout android:id="@+id/emptyKhataEntryState"
                        android:layout_width="match_parent" android:layout_height="60dp"
                        android:gravity="center" android:visibility="gone">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="কোনো দেনা-পাওনা নেই"
                            android:textSize="13sp" android:textColor="@color/textSecondary"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
