<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgColor">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:paddingBottom="30dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- হেডার -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_header_ledger"
                android:paddingHorizontal="10dp"
                android:paddingVertical="12dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:padding="10dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@color/white"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="নতুন ব্যক্তি"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>
            </LinearLayout>

            <!-- ছবি -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="22dp">

                <FrameLayout
                    android:id="@+id/photoFrame"
                    android:layout_width="112dp"
                    android:layout_height="112dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/ivPersonPhoto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone"/>

                    <View
                        android:id="@+id/photoRing"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_person_photo_filled_ring"
                        android:visibility="gone"/>

                    <LinearLayout
                        android:id="@+id/photoPlaceholder"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_person_photo_placeholder"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:src="@drawable/ic_camera_add"
                            app:tint="#E2136E"/>
                    </LinearLayout>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_camera_badge_pink"
                    android:gravity="center"
                    android:clickable="false"
                    android:focusable="false">

                    <ImageView
                        android:layout_width="17dp"
                        android:layout_height="17dp"
                        android:src="@drawable/ic_camera_add"/>
                </LinearLayout>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:text="ছবি যোগ করুন (ঐচ্ছিক)"
                android:textSize="12.5sp"
                android:textColor="@color/textSecondary"/>

            <!-- ফর্ম কার্ড -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/cardBg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- নাম + সম্পর্ক (একই লাইনে) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="নাম"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/textSecondary"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/etName"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_card_white"
                            android:paddingHorizontal="16dp"
                            android:hint="ব্যক্তি বা প্রতিষ্ঠানের নাম"
                            android:textColor="@color/textPrimary"
                            android:textColorHint="@color/hintTextLight"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:inputType="textPersonName|textCapWords"/>

                        <EditText
                            android:id="@+id/etRelation"
                            android:layout_width="92dp"
                            android:layout_height="56dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_relation_chip"
                            android:paddingHorizontal="12dp"
                            android:hint="সম্পর্ক"
                            android:gravity="center"
                            android:textColor="#B3105A"
                            android:textColorHint="#C97AA0"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:inputType="text"/>
                    </LinearLayout>

                    <!-- মোবাইল নম্বর -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="মোবাইল নম্বর (ঐচ্ছিক)"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="18dp"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_card_white"
                        android:paddingStart="16dp"
                        android:paddingEnd="6dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_call_filled"
                            app:tint="#E2136E"
                            android:layout_marginEnd="10dp"/>

                        <EditText
                            android:id="@+id/etPhone"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:hint="ফোন নম্বর লিখুন"
                            android:textColor="@color/textPrimary"
                            android:textColorHint="@color/hintTextLight"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:inputType="phone"/>

                        <ImageView
                            android:id="@+id/btnPickContact"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:padding="9dp"
                            android:src="@drawable/ic_contact_book"
                            android:background="@drawable/bg_contact_pick_btn"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>

                    <!-- ঠিকানা -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ঠিকানা (ঐচ্ছিক)"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="18dp"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_card_white"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_location_pin"
                            android:layout_marginEnd="10dp"/>

                        <EditText
                            android:id="@+id/etAddress"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:hint="ঠিকানা লিখুন"
                            android:textColor="@color/textPrimary"
                            android:textColorHint="@color/hintTextLight"
                            android:textSize="15sp"
                            android:maxLines="1"
                            android:inputType="textPostalAddress|textCapSentences"/>
                    </LinearLayout>

                    <!-- ইমেইল -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ইমেইল (ঐচ্ছিক)"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="18dp"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_card_white"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_mail"
                            app:tint="@color/textSecondary"
                            android:layout_marginEnd="10dp"/>

                        <EditText
                            android:id="@+id/etEmail"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:hint="ইমেইল ঠিকানা লিখুন"
                            android:textColor="@color/textPrimary"
                            android:textColorHint="@color/hintTextLight"
                            android:textSize="15sp"
                            android:maxLines="1"
                            android:inputType="textEmailAddress"/>
                    </LinearLayout>

                    <!-- তারিখ ও সময় -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="তারিখ ও সময়"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/textSecondary"
                        android:layout_marginTop="18dp"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/tvDate"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_card_white"
                            android:paddingHorizontal="14dp"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="17dp"
                                android:layout_height="17dp"
                                android:src="@drawable/ic_calendar"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:id="@+id/tvDateText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="13.5sp"
                                android:textStyle="bold"
                                android:textColor="@color/textPrimary"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/tvTime"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_card_white"
                            android:paddingHorizontal="14dp"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:id="@+id/tvTimeText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="13.5sp"
                                android:textStyle="bold"
                                android:textColor="@color/textPrimary"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- সেইভ বাটন -->
            <LinearLayout
                android:id="@+id/btnSavePerson"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="14dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_btn_ledger"
                android:gravity="center"
                android:enabled="false"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="সেইভ করুন"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
