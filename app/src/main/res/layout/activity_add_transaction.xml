<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgColor">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:fillViewport="true"
        android:paddingBottom="28dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== Header ===== -->
            <LinearLayout
                android:id="@+id/headerTxn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_header_txn"
                android:orientation="vertical"
                android:paddingTop="16dp"
                android:paddingBottom="24dp"
                android:paddingHorizontal="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="5dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="আয় ব্যয় হিসাব"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.01"
                        android:textColor="@color/white"/>

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_txn_wallet_badge">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_wallet_txn"/>
                    </FrameLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- ===== Body ===== -->
            <LinearLayout
                android:id="@+id/bodyContainerTxn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <!-- Tab Switch -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_txn_tab_container"
                    android:orientation="horizontal"
                    android:padding="5dp"
                    android:elevation="4dp">

                    <TextView
                        android:id="@+id/tabIncome"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="আয় যুক্ত করুন"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_txn_tab_selected_income"
                        android:textColor="@color/white"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/tabExpense"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="ব্যয় যুক্ত করুন"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/txnTabInactiveText"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- ===== AI ভয়েস দিয়ে যোগ করুন — এক ক্লিকে ===== -->
                <LinearLayout
                    android:id="@+id/btnAiVoiceEntry"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_ai_voice_pill"
                    android:elevation="3dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/ivAiMic"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_mic_ai"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tvAiVoiceLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✨ ভয়েসে বলুন, AI যোগ করে দেবে"
                        android:textSize="14.5sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"/>
                </LinearLayout>

                <!-- Amount / Note + Save circle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp"
                    android:gravity="top">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="14dp">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilAmount"
                            style="@style/AppTextInputSmooth"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="আয়ের পরিমাণ"
                            android:layout_marginBottom="14dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etAmount"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:paddingVertical="14dp"
                                android:inputType="numberDecimal"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-black"
                                android:letterSpacing="0.01"
                                android:textColor="@color/textPrimary"
                                android:imeOptions="actionNext"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilNote"
                            style="@style/AppTextInputSmooth"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="নোট">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etNote"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textMultiLine|textCapSentences"
                                android:minLines="2"
                                android:maxLines="4"
                                android:gravity="top"
                                android:textStyle="bold"
                                android:textSize="14sp"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="152dp"
                        android:layout_height="152dp">

                        <View
                            android:id="@+id/ringSaveTxn"
                            android:layout_width="152dp"
                            android:layout_height="152dp"
                            android:layout_gravity="center"
                            android:background="@drawable/ring_outline_green"/>

                        <Button
                            android:id="@+id/btnSaveTxn"
                            android:layout_width="128dp"
                            android:layout_height="128dp"
                            android:layout_gravity="center"
                            android:background="@drawable/circle_gradient_green"
                            android:text="আয়\nসংরক্ষণ"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black"
                            android:textColor="@color/white"
                            android:stateListAnimator="@null"
                            android:elevation="8dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"/>
                    </FrameLayout>
                </LinearLayout>

                <!-- ===== Category — উন্নত, টাইপ-করা যায় এমন সিস্টেম ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="10dp"
                    android:text="ক্যাটাগরি"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/textPrimary"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilCategory"
                    style="@style/AppTextInputSmooth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="ক্যাটাগরি লিখুন বা নিচ থেকে বাছুন"
                    app:startIconDrawable="@drawable/ic_plus_circle_txn"
                    app:startIconTint="@null">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCategory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="14dp"
                        android:inputType="textCapSentences"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:imeOptions="actionDone"/>
                </com.google.android.material.textfield.TextInputLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:id="@+id/chipGroupCategories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"/>
                </HorizontalScrollView>

                <!-- Date / Time -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">

                    <TextView
                        android:id="@+id/tvDate"
                        android:layout_width="0dp"
                        android:layout_height="58dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:gravity="center"
                        android:background="@drawable/bg_txn_chip_blue"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/tvTime"
                        android:layout_width="0dp"
                        android:layout_height="58dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:gravity="center"
                        android:background="@drawable/bg_txn_chip_blue"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- ===== Payment Method — লেনদেন মাধ্যম ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:layout_marginBottom="10dp"
                    android:text="পেমেন্টের ধরণ"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/textPrimary"/>

                <LinearLayout
                    android:id="@+id/rowPaymentMethods1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:id="@+id/rowPaymentMethods2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ===== AI ভাবছে... — ব্লার ওভারলে ===== -->
    <FrameLayout
        android:id="@+id/aiThinkingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/ivAiBlurBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#59000000"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_ai_thinking_card"
            android:paddingHorizontal="34dp"
            android:paddingVertical="28dp"
            android:elevation="10dp">

            <ProgressBar
                android:id="@+id/pbAiThinking"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:indeterminateTint="@color/white"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvAiThinking"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI ভাবছে..."
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/white"/>
        </LinearLayout>
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
