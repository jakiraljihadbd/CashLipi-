<?xml version="1.0" encoding="utf-8"?>
<!--
    App Lock Setup — Material 3 (Material You) wizard.
    Premium purple/indigo palette, all colors driven from colors.xml
    (applock* tokens) so the theme can be re-skinned without touching code.

    Steps (one FrameLayout child visible at a time, swapped in Java):
      stepIntro      → "Protect Your Data" welcome card
      stepPin        → shared 4-digit PIN keypad, reused for Create + Confirm
      stepQuestion   → choose ONE recovery question + single answer field
      stepFingerprint→ optional biometric unlock toggle
      stepSuccess    → "App Lock Enabled" confirmation
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/applockBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ══════ Top bar: back button · step title · skip ══════ -->
        <LinearLayout
            android:id="@+id/layoutTopBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingTop="14dp"
            android:paddingBottom="6dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_applock_button_outline"
                android:src="@drawable/ic_arrow_back"
                android:tint="@color/applockPrimary"
                android:padding="10dp"
                android:contentDescription="পেছনে যান"/>

            <TextView
                android:id="@+id/tvStepTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="অ্যাপ লক সেটআপ"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/applockTextPrimary"/>

            <TextView
                android:id="@+id/tvSkip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skip"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/applockTextSecondary"
                android:padding="10dp"
                android:background="?attr/selectableItemBackground"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- ══════ Step progress dots ══════ -->
        <LinearLayout
            android:id="@+id/layoutStepDots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp">

            <View android:id="@+id/dotStep1" android:layout_width="22dp" android:layout_height="8dp"
                android:layout_marginHorizontal="4dp" android:background="@drawable/shape_applock_step_dot_active"/>
            <View android:id="@+id/dotStep2" android:layout_width="8dp" android:layout_height="8dp"
                android:layout_marginHorizontal="4dp" android:background="@drawable/shape_applock_step_dot_inactive"/>
            <View android:id="@+id/dotStep3" android:layout_width="8dp" android:layout_height="8dp"
                android:layout_marginHorizontal="4dp" android:background="@drawable/shape_applock_step_dot_inactive"/>
            <View android:id="@+id/dotStep4" android:layout_width="8dp" android:layout_height="8dp"
                android:layout_marginHorizontal="4dp" android:background="@drawable/shape_applock_step_dot_inactive"/>
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            android:fillViewport="true">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:paddingBottom="24dp">

                <!-- ══════════════════════ STEP: INTRO ══════════════════════ -->
                <LinearLayout
                    android:id="@+id/stepIntro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingTop="24dp">

                    <FrameLayout
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:layout_marginBottom="28dp">
                        <View android:layout_width="140dp" android:layout_height="140dp"
                            android:background="@drawable/bg_applock_icon_circle"/>
                        <ImageView
                            android:id="@+id/ivIntroShield"
                            android:layout_width="64dp" android:layout_height="64dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_shield"
                            android:tint="@color/applockPrimary"
                            android:contentDescription="শিল্ড"/>
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvIntroTitle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Protect Your Data"
                        android:textSize="22sp" android:textStyle="bold"
                        android:textColor="@color/applockTextPrimary"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvIntroSubtitle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Set a 4-digit PIN to keep your app and data secure."
                        android:textSize="14sp" android:gravity="center"
                        android:textColor="@color/applockTextSecondary"
                        android:lineSpacingExtra="3dp"
                        android:layout_marginBottom="36dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartSetup"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:text="Create PIN"
                        android:textAllCaps="false" android:textSize="16sp" android:textStyle="bold"
                        android:textColor="@color/applockOnPrimary"
                        app:cornerRadius="20dp"
                        app:backgroundTint="@color/applockPrimary"
                        app:rippleColor="@color/applockOnPrimary"
                        app:icon="@drawable/ic_applock_lock"
                        app:iconTint="@color/applockOnPrimary"
                        app:iconGravity="textStart"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSkipIntro"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:layout_marginTop="10dp"
                        android:text="Skip for now"
                        android:textAllCaps="false" android:textSize="14sp"
                        android:textColor="@color/applockTextSecondary"
                        app:cornerRadius="20dp"
                        app:backgroundTint="@android:color/transparent"
                        app:rippleColor="@color/applockRipple"
                        app:strokeColor="@android:color/transparent"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDisableLock"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:layout_marginTop="10dp"
                        android:text="Disable App Lock"
                        android:textAllCaps="false" android:textSize="14sp" android:textStyle="bold"
                        android:textColor="@color/applockError"
                        app:cornerRadius="20dp"
                        app:backgroundTint="@android:color/transparent"
                        app:rippleColor="@color/applockErrorContainer"
                        app:strokeColor="@color/applockError"
                        app:strokeWidth="1.5dp"
                        android:visibility="gone"/>
                </LinearLayout>

                <!-- ══════════════════════ STEP: PIN (create + confirm, reused) ══════════════════════ -->
                <LinearLayout
                    android:id="@+id/stepPin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:visibility="gone"
                    android:paddingTop="12dp">

                    <FrameLayout
                        android:layout_width="80dp" android:layout_height="80dp"
                        android:layout_marginBottom="18dp">
                        <View android:layout_width="80dp" android:layout_height="80dp"
                            android:background="@drawable/bg_applock_icon_circle_solid"/>
                        <ImageView
                            android:layout_width="34dp" android:layout_height="34dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_applock_lock"
                            android:contentDescription="লক"/>
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvPinTitle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Create Your App Lock"
                        android:textSize="20sp" android:textStyle="bold"
                        android:textColor="@color/applockTextPrimary"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tvPinSubtitle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Protect your personal data using a secure 4-digit PIN."
                        android:textSize="13sp" android:gravity="center"
                        android:textColor="@color/applockTextSecondary"
                        android:paddingHorizontal="12dp"
                        android:lineSpacingExtra="3dp"
                        android:layout_marginBottom="26dp"/>

                    <!-- PIN dots -->
                    <LinearLayout
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">
                        <View android:id="@+id/dotPin1" android:layout_width="16dp" android:layout_height="16dp"
                            android:layout_marginHorizontal="9dp" android:background="@drawable/shape_applock_pin_dot_empty"/>
                        <View android:id="@+id/dotPin2" android:layout_width="16dp" android:layout_height="16dp"
                            android:layout_marginHorizontal="9dp" android:background="@drawable/shape_applock_pin_dot_empty"/>
                        <View android:id="@+id/dotPin3" android:layout_width="16dp" android:layout_height="16dp"
                            android:layout_marginHorizontal="9dp" android:background="@drawable/shape_applock_pin_dot_empty"/>
                        <View android:id="@+id/dotPin4" android:layout_width="16dp" android:layout_height="16dp"
                            android:layout_marginHorizontal="9dp" android:background="@drawable/shape_applock_pin_dot_empty"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvPinError"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:background="@drawable/bg_applock_error_pill"
                        android:paddingHorizontal="16dp" android:paddingVertical="8dp"
                        android:textColor="@color/applockError" android:textSize="12sp"
                        android:textStyle="bold" android:layout_marginBottom="6dp"
                        android:visibility="invisible"
                        android:text="PIN মেলেনি, আবার চেষ্টা করুন"/>

                    <!-- Numeric keypad -->
                    <GridLayout
                        android:id="@+id/keypad"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:columnCount="3" android:rowCount="4"
                        android:layout_marginTop="8dp">

                        <TextView android:id="@+id/keyPad1" style="@style/AppLockKeypadKey" android:text="1"/>
                        <TextView android:id="@+id/keyPad2" style="@style/AppLockKeypadKey" android:text="2"/>
                        <TextView android:id="@+id/keyPad3" style="@style/AppLockKeypadKey" android:text="3"/>

                        <TextView android:id="@+id/keyPad4" style="@style/AppLockKeypadKey" android:text="4"/>
                        <TextView android:id="@+id/keyPad5" style="@style/AppLockKeypadKey" android:text="5"/>
                        <TextView android:id="@+id/keyPad6" style="@style/AppLockKeypadKey" android:text="6"/>

                        <TextView android:id="@+id/keyPad7" style="@style/AppLockKeypadKey" android:text="7"/>
                        <TextView android:id="@+id/keyPad8" style="@style/AppLockKeypadKey" android:text="8"/>
                        <TextView android:id="@+id/keyPad9" style="@style/AppLockKeypadKey" android:text="9"/>

                        <View android:layout_width="60dp" android:layout_height="60dp" android:layout_margin="6dp"/>
                        <TextView android:id="@+id/keyPad0" style="@style/AppLockKeypadKey" android:text="0"/>
                        <TextView android:id="@+id/keyBackspace" style="@style/AppLockKeypadKey"
                            android:text="⌫" android:textSize="20sp"/>
                    </GridLayout>
                </LinearLayout>

                <!-- ══════════════════════ STEP: SECURITY QUESTION ══════════════════════ -->
                <LinearLayout
                    android:id="@+id/stepQuestion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:visibility="gone"
                    android:paddingTop="12dp">

                    <FrameLayout
                        android:layout_width="80dp" android:layout_height="80dp"
                        android:layout_marginBottom="16dp">
                        <View android:layout_width="80dp" android:layout_height="80dp"
                            android:background="@drawable/bg_applock_icon_circle_solid"/>
                        <ImageView
                            android:layout_width="34dp" android:layout_height="34dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_applock_help"
                            android:contentDescription="প্রশ্ন"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Recovery Question"
                        android:textSize="20sp" android:textStyle="bold"
                        android:textColor="@color/applockTextPrimary"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Choose ONE security question. This will be used if you forget your PIN."
                        android:textSize="13sp" android:gravity="center"
                        android:textColor="@color/applockTextSecondary"
                        android:paddingHorizontal="12dp"
                        android:lineSpacingExtra="3dp"
                        android:layout_marginBottom="20dp"/>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        app:cardCornerRadius="20dp" app:cardElevation="2dp"
                        app:strokeWidth="1dp" app:strokeColor="@color/applockOutlineSoft"
                        app:cardBackgroundColor="@color/applockSurface">

                        <RadioGroup
                            android:id="@+id/radioGroupQuestions"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingVertical="4dp">

                            <RadioButton android:id="@+id/radioQ0" style="@style/AppLockQuestionRadio"/>
                            <View style="@style/AppLockDivider"/>
                            <RadioButton android:id="@+id/radioQ1" style="@style/AppLockQuestionRadio"/>
                            <View style="@style/AppLockDivider"/>
                            <RadioButton android:id="@+id/radioQ2" style="@style/AppLockQuestionRadio"/>
                            <View style="@style/AppLockDivider"/>
                            <RadioButton android:id="@+id/radioQ3" style="@style/AppLockQuestionRadio"/>
                            <View style="@style/AppLockDivider"/>
                            <RadioButton android:id="@+id/radioQ4" style="@style/AppLockQuestionRadio"/>
                        </RadioGroup>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutAnswer"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:hint="Your Answer"
                        android:visibility="gone"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp"
                        app:boxStrokeColor="@color/applockPrimary"
                        app:hintTextColor="@color/applockPrimary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etAnswer"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:textColor="@color/applockTextPrimary"
                            android:textSize="15sp"
                            android:inputType="text"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNextQuestion"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:layout_marginTop="28dp"
                        android:text="Next"
                        android:textAllCaps="false" android:textSize="16sp" android:textStyle="bold"
                        android:textColor="@color/applockOnPrimary"
                        app:cornerRadius="20dp"
                        app:backgroundTint="@color/applockPrimary"
                        app:rippleColor="@color/applockOnPrimary"/>
                </LinearLayout>

                <!-- ══════════════════════ STEP: FINGERPRINT ══════════════════════ -->
                <LinearLayout
                    android:id="@+id/stepFingerprint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:visibility="gone"
                    android:paddingTop="16dp">

                    <FrameLayout
                        android:layout_width="140dp" android:layout_height="140dp"
                        android:layout_marginBottom="24dp">
                        <View android:layout_width="140dp" android:layout_height="140dp"
                            android:background="@drawable/bg_applock_icon_circle"/>
                        <ImageView
                            android:layout_width="60dp" android:layout_height="60dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_fingerprint"
                            android:tint="@color/applockPrimary"
                            android:contentDescription="ফিঙ্গারপ্রিন্ট"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Enable Fingerprint"
                        android:textSize="20sp" android:textStyle="bold"
                        android:textColor="@color/applockTextPrimary"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Unlock your app faster using fingerprint authentication."
                        android:textSize="13sp" android:gravity="center"
                        android:textColor="@color/applockTextSecondary"
                        android:paddingHorizontal="16dp"
                        android:lineSpacingExtra="3dp"
                        android:layout_marginBottom="24dp"/>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        app:cardCornerRadius="20dp" app:cardElevation="2dp"
                        app:strokeWidth="1dp" app:strokeColor="@color/applockOutlineSoft"
                        app:cardBackgroundColor="@color/applockSurface">

                        <LinearLayout
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:padding="18dp">

                            <TextView
                                android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Enable Fingerprint"
                                android:textSize="15sp" android:textStyle="bold"
                                android:textColor="@color/applockTextPrimary"/>

                            <androidx.appcompat.widget.SwitchCompat
                                android:id="@+id/switchFingerprint"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                app:thumbTint="@color/applockPrimary"
                                app:trackTint="@color/applockPrimaryContainer"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvFingerprintUnavailable"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Fingerprint is not available on this device."
                        android:textSize="12sp" android:textColor="@color/applockError"
                        android:layout_marginTop="12dp"
                        android:visibility="gone"/>

                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="28dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBackFingerprint"
                            android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="Back"
                            android:textAllCaps="false" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/applockTextSecondary"
                            app:cornerRadius="18dp"
                            app:strokeColor="@color/applockOutline" app:strokeWidth="1.5dp"
                            app:backgroundTint="@color/applockSurface"
                            app:rippleColor="@color/applockRipple"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFinish"
                            android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="Finish"
                            android:textAllCaps="false" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/applockOnPrimary"
                            app:cornerRadius="18dp"
                            app:backgroundTint="@color/applockPrimary"
                            app:rippleColor="@color/applockOnPrimary"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- ══════════════════════ STEP: SUCCESS ══════════════════════ -->
                <LinearLayout
                    android:id="@+id/stepSuccess"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:visibility="gone"
                    android:paddingTop="40dp">

                    <FrameLayout
                        android:id="@+id/successIconFrame"
                        android:layout_width="140dp" android:layout_height="140dp"
                        android:layout_marginBottom="28dp">
                        <View android:layout_width="140dp" android:layout_height="140dp"
                            android:background="@drawable/bg_applock_success_circle"/>
                        <ImageView
                            android:layout_width="70dp" android:layout_height="70dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_check_circle"
                            android:tint="@color/applockSuccess"
                            android:contentDescription="সফল"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="App Lock Enabled"
                        android:textSize="22sp" android:textStyle="bold"
                        android:textColor="@color/applockTextPrimary"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Your application is now protected."
                        android:textSize="14sp"
                        android:textColor="@color/applockTextSecondary"
                        android:layout_marginBottom="40dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGoToDashboard"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:text="Go to Dashboard"
                        android:textAllCaps="false" android:textSize="16sp" android:textStyle="bold"
                        android:textColor="@color/applockOnPrimary"
                        app:cornerRadius="20dp"
                        app:backgroundTint="@color/applockPrimary"
                        app:rippleColor="@color/applockOnPrimary"/>
                </LinearLayout>

            </FrameLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</FrameLayout>
