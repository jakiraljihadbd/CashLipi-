<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bkSurface">

    <!-- ── HEADER ──────────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_blue_purple"
        android:orientation="vertical"
        android:paddingTop="52dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="20dp">

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Backup History"
                android:textColor="@color/bkTextPrimary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingStart="12dp"/>

            <ImageView android:id="@+id/btnClearHistory"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/emoji_trash"
                android:scaleType="centerInside"
                android:padding="4dp"/>
        </LinearLayout>

        <TextView android:id="@+id/tvHistoryCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0টি ব্যাকআপ পাওয়া গেছে"
            android:textColor="@color/bkTextSecondary"
            android:textSize="12sp"
            android:paddingStart="52dp"/>
    </LinearLayout>

    <!-- ── FILTER CHIPS ──────────────────────────────────────────────────── -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <LinearLayout android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.cardview.widget.CardView
                android:id="@+id/chipFilterAll"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="@color/gradCircleBlueEnd"
                app:cardElevation="2dp">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="  সব  "
                    android:textColor="@color/bkTextPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"/>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/chipFilterTelegram"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="@color/bkCardInner"
                app:cardElevation="2dp">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="   Telegram  "
                    android:textColor="@color/bkTextSecondary"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"/>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/chipFilterGDrive"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="@color/bkCardInner"
                app:cardElevation="2dp">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="   Google Drive  "
                    android:textColor="@color/bkTextSecondary"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"/>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/chipFilterLocal"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="@color/bkCardInner"
                app:cardElevation="2dp">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="   Local  "
                    android:textColor="@color/bkTextSecondary"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"/>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- ── EMPTY STATE ────────────────────────────────────────────────────── -->
    <LinearLayout android:id="@+id/tvEmptyHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="48dp"
        android:visibility="gone">
        <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:src="@drawable/emoji_floppy_disk" android:scaleType="centerInside"/>
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="কোনো ব্যাকআপ ইতিহাস নেই"
            android:textColor="@color/bkTextPrimary"
            android:textSize="16sp"
            android:textStyle="bold"/>
        <TextView android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="প্রথম ব্যাকআপ তৈরি করুন"
            android:textColor="@color/bkTextSecondary"
            android:textSize="13sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- ── HISTORY LIST ───────────────────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvBackupHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"/>

</LinearLayout>
