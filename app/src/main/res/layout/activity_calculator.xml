<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/calcBg">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="16dp" android:paddingTop="12dp" android:paddingBottom="8dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text=" ক্যালকুলেটর" android:textSize="18sp"
            android:textStyle="bold" android:textColor="@color/white"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="130dp"
        android:orientation="vertical" android:gravity="bottom|end"
        android:background="@color/calcDisplay" android:paddingHorizontal="16dp"
        android:paddingVertical="12dp" android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="8dp">
        <TextView android:id="@+id/tvExpression" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="" android:textSize="16sp"
            android:textColor="@color/secondaryTextDark" android:gravity="end" android:maxLines="1"
            android:ellipsize="start"/>
        <TextView android:id="@+id/tvResult" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="0" android:textSize="42sp"
            android:textStyle="bold" android:textColor="@color/white" android:gravity="end"
            android:maxLines="1" android:ellipsize="start"/>
    </LinearLayout>
    <GridLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:columnCount="4"
        android:rowCount="5" android:padding="8dp" android:useDefaultMargins="true">
        <Button android:id="@+id/btnClear" style="@style/CalcBtn.Special"
            android:layout_width="0dp" android:layout_height="@dimen/calc_btn_height"
            android:layout_columnWeight="1" android:text="AC"/>
        <Button android:id="@+id/btnPlusMinus" style="@style/CalcBtn.Special"
            android:layout_width="0dp" android:layout_height="@dimen/calc_btn_height"
            android:layout_columnWeight="1" android:text="+/-"/>
        <Button android:id="@+id/btnPercent" style="@style/CalcBtn.Special"
            android:layout_width="0dp" android:layout_height="@dimen/calc_btn_height"
            android:layout_columnWeight="1" android:text="%"/>
        <Button android:id="@+id/btnDivide" style="@style/CalcBtn.Operator"
            android:layout_width="0dp" android:layout_height="@dimen/calc_btn_height"
            android:layout_columnWeight="1" android:text="÷"/>
        <Button android:id="@+id/btn7" style="@style/CalcBtn"
            android:layout_width="0dp" android:layout_height="@dimen/calc_btn_height"
            android:layout_columnWeight="1" android:text="৭"/>
        <Button android:id="@+id/btn8" style="@style/CalcBtn"
            android:layout_width="0dp" android:layout_height="@dimen/calc_btn_height"
            android:layout_columnWeight="1" android:text="৮"/>
        <Button android:id="@+id/btn9" style="@style/CalcBtn"
            android:layout_width="0dp" android:layout_height="@dimen/calc_btn_height"
            android:layout_columnWeight="1" android:text="৯"/>
        <Button android:id="@+id/btnMultiply" style="@style/CalcBtn.Operator"
            android:layout_width="0dp" android:layout_height="@dimen/calc_btn_height"
            android:layout_columnWeight="1" android:text="×"/>
        <Button android:id="@+id/btn4" style="@style/CalcBtn"
            android:layout_width="0dp" android:layout_height="@dimen/calc_btn_height"
            android:layout_columnWeight="1" android:text="৪"/>
        <Button android:id="@+id/btn5" style="@style/CalcBtn"
            android:layout_width="0dp" android:layout_height="@dimen/calc_btn_height"
            android:layout_columnWeight="1" android:text="৫"/>
        <Button android:id="@+id/btn6" style="@style/CalcBtn"
            android:layout_width="0dp" android:layout_height="@dimen/calc_btn_height"
            android:layout_columnWeight="1" android:text="৬"/>
        <Button android:id="@+id/btnMinus" style="@style/CalcBtn.Operator"
            android:layout_width="0dp" android:layout_height="@dimen/calc_btn_height"
            android:layout_columnWeight="1" android:text="−"/>
        <Button android:id="@+id/btn1" style="@style/CalcBtn"
            android:layout_width="0dp" android:layout_height="@dimen/calc_btn_height"
            android:layout_columnWeight="1" android:text="১"/>
        <Button android:id="@+id/btn2" style="@style/CalcBtn"
            android:layout_width="0dp" android:layout_height="@dimen/calc_btn_height"
            android:layout_columnWeight="1" android:text="২"/>
        <Button android:id="@+id/btn3" style="@style/CalcBtn"
            android:layout_width="0dp" android:layout_height="@dimen/calc_btn_height"
            android:layout_columnWeight="1" android:text="৩"/>
        <Button android:id="@+id/btnPlus" style="@style/CalcBtn.Operator"
            android:layout_width="0dp" android:layout_height="@dimen/calc_btn_height"
            android:layout_columnWeight="1" android:text="+"/>
        <Button android:id="@+id/btn0" style="@style/CalcBtn"
            android:layout_width="0dp" android:layout_height="@dimen/calc_btn_height"
            android:layout_columnWeight="2" android:text="০"/>
        <Button android:id="@+id/btnDot" style="@style/CalcBtn"
            android:layout_width="0dp" android:layout_height="@dimen/calc_btn_height"
            android:layout_columnWeight="1" android:text="."/>
        <Button android:id="@+id/btnEquals" style="@style/CalcBtn.Equal"
            android:layout_width="0dp" android:layout_height="@dimen/calc_btn_height"
            android:layout_columnWeight="1" android:text="="/>
        <Button android:id="@+id/btnBackspace" style="@style/CalcBtn.Special"
            android:layout_width="match_parent" android:layout_height="@dimen/calc_btn_height"
            android:layout_columnSpan="4" android:text=" মুছুন"/>
    </GridLayout>
</LinearLayout>
