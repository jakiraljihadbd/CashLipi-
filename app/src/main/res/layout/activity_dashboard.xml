<?xml version="1.0" encoding="utf-8"?>
<!--
    CashLipi — Dashboard container (UI/Navigation upgrade v3)
    ভেতরে থাকে:
      (১) কমপ্যাক্ট ব্র্যান্ড হেডার (স্ট্যাটিক "CashLipi") + Add (+) বাটন + headerSliderSlot (ফাঁকা —
          ব্যালেন্স/টাইটেল-সাইকেল সরিয়ে এখানে ভবিষ্যতে স্লাইড/AI-advice কার্ড বসবে)
      (২) ৭-আইকন নেভ বার — সেটিং অনুযায়ী "উপরে" (ডিফল্ট) অথবা "নিচে" পজিশনে বসে (topNavBar ভিউটাই রিপ্যারেন্ট হয়)
      (৩) নিচে পজিশনে থাকলে — bottomNavContainer দেখানো হয়, bottomNavSlot-এর ব্যাকগ্রাউন্ড এখন
          NotchedBarDrawable (কোডে বসানো) — বারের সিলুয়েটেই + বাটনের জন্য সত্যিকারের বাঁকানো
          কাটআউট/কার্ভ (cradle) আঁকা হয়, + বাটন সেই গর্তের মধ্যেই বসে (fabNotchBackdrop ভিউটা
          পুরনো হ্যাক ছিল, এখন GONE — আর ব্যবহার হয় না)
      (৪) ViewPager2 — ৭টি Fragment পেজ (সোয়াইপ অন/অফ সেটিং দিয়ে নিয়ন্ত্রিত)
      (৫) fabMenuOverlay — + বাটনে ট্যাপ করলে ফ্যান-আউট অ্যানিমেশনে ৪টা অপশন ভাসে (স্ক্রিমসহ)
-->
<androidx.drawerlayout.widget.DrawerLayout
    android:id="@+id/dashboardDrawerLayout"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:background="@color/bgColor">

        <!-- ══════════════════════════════════════════════════════════
             TOP IDENTITY BAR — সবসময় দৃশ্যমান (নেভ পজিশন সেটিং নির্বিশেষে)।
             বামে হ্যামবার্গার মেনু, মাঝে সালাম/অ্যাপ-নাম/সময়/তারিখ — একের পর এক স্লাইড,
             ডানে নোটিফিকেশন + প্রোফাইল আইকন। রং = ব্যালেন্স কার্ডের রং, চিকন বার।
        ══════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/topIdentityBar"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/m3HomeBalanceContainer"
            android:paddingHorizontal="8dp">

            <ImageButton
                android:id="@+id/headerMenuBtn"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:padding="7dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_menu_hamburger"
                app:tint="#FFFFFF"
                android:contentDescription="মেনু"/>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp">

                <ViewFlipper
                    android:id="@+id/headerIdentityFlipper"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:flipInterval="2600"
                    android:inAnimation="@anim/slide_in_right"
                    android:outAnimation="@anim/slide_out_left">
                    <!-- চাইল্ড TextView গুলো DashboardActivity.java থেকে রানটাইমে যোগ হয় -->
                </ViewFlipper>
            </FrameLayout>

            <ImageButton
                android:id="@+id/headerNotifBtn"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:padding="9dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_bell_notification"
                app:tint="#FFFFFF"
                android:contentDescription="নোটিফিকেশন"/>

            <ImageButton
                android:id="@+id/headerProfileBtn"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:padding="8dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_person_circle"
                app:tint="#FFFFFF"
                android:contentDescription="প্রোফাইল"/>
        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════
             TOP BLOCK — হেডার (+ Add বাটন) + headerSliderSlot (ফাঁকা) + topNavSlot
        ══════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/topBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/transparent">

            <!-- Add বাটন — CashLipi ব্র্যান্ড বার সরিয়ে দেওয়া হয়েছে, শুধু + বাটন থাকবে।
                 নিচের পজিশনে এই সারিটা পুরো লুকানো হয় (headerRow GONE, কোডে) — নাহলে খালি একটা
                 সাদা/ফাঁকা স্ট্রিপ থেকে যেত। উপরের পজিশনে নেভবারের সাথে একই রঙে (navBgColor) রাঙানো
                 হয় যাতে হেডার+নেভবার একটানা একটা বার মনে হয়, আলাদা সাদা অংশ চোখে না পড়ে। -->
            <LinearLayout
                android:id="@+id/headerRow"
                android:layout_width="match_parent"
                android:layout_height="@dimen/top_header_height"
                android:orientation="horizontal"
                android:gravity="center_vertical|end"
                android:paddingHorizontal="16dp">

                <!-- Add (+) বাটন — ট্যাপ করলে ফ্যান-আউট মেন্যু: আয়-ব্যয় যোগ / দেনা-পাওনা যোগ / সঞ্চয় যোগ / সেটিং -->
                <ImageButton
                    android:id="@+id/headerAddBtn"
                    android:layout_width="@dimen/header_add_btn_size"
                    android:layout_height="@dimen/header_add_btn_size"
                    android:padding="7dp"
                    android:background="@drawable/bg_fab_add"
                    android:src="@drawable/ic_plus"
                    android:contentDescription="@string/add_menu_title"
                    android:scaleType="fitCenter"
                    android:elevation="3dp"/>
            </LinearLayout>

            <!-- headerSliderSlot — HomeFragment-এ নিজস্ব "স্মার্ট পরামর্শ" carousel থাকায় এই পুরনো
                 ডুপ্লিকেট ব্যানারটা লুকানো হলো — হেডার হাইট কমাতে ও পুনরাবৃত্তি এড়াতে। -->
            <FrameLayout
                android:id="@+id/headerSliderSlot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone">

                <ViewFlipper
                    android:id="@+id/headerAiFlipper"
                    android:layout_width="match_parent"
                    android:layout_height="34dp"
                    android:background="@color/m3HomeBalanceContainer"
                    android:flipInterval="4000"
                    android:inAnimation="@anim/slide_in_right"
                    android:outAnimation="@anim/slide_out_left"
                    android:clickable="true" android:focusable="true">
                    <!-- চাইল্ড TextView গুলো DashboardActivity.java থেকে রানটাইমে যোগ হয় -->
                </ViewFlipper>
            </FrameLayout>

            <!-- নেভ বার এখানে বসে (পজিশন = "উপরে", ডিফল্ট) — topNavBar রানটাইমে এখানে inflate/attach হয় -->
            <FrameLayout
                android:id="@+id/topNavSlot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- টপ ব্লকের একদম নিচে ডিভাইডার — স্মার্ট পরামর্শ কার্ডের ঠিক উপরে একটা সোজা দাগের
                 মতো দেখাচ্ছিল বলে সরিয়ে দেওয়া হলো (GONE, ভিউটা কোডে রেফারেন্স থাকলে যেন ক্র্যাশ না করে) -->
            <View
                android:id="@+id/topBlockDivider"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@drawable/dash_accent_line"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════
             ৭টি পেজ — সোয়াইপ (সেটিং দিয়ে অন/অফ) + ট্যাপ নেভিগেশন
        ══════════════════════════════════════════════════════════ -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- ══════════════════════════════════════════════════════════
             BOTTOM BLOCK — পজিশন = "নিচে" হলে দেখানো হয়। bottomNavSlot-এ topNavBar রিপ্যারেন্ট হয়,
             fabNotchBackdrop বারের রং দিয়ে + বাটনের পেছনে গোল "কুশন" তৈরি করে যাতে + বাটনটা বারের
             সাথে মিশে আধুনিক কার্ভ লুক দেয় (bg_fab_add-এর নিচে একটা বড়, একই-রঙা বৃত্ত)।
        ══════════════════════════════════════════════════════════ -->
        <FrameLayout
            android:id="@+id/bottomNavContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:visibility="gone">

            <FrameLayout
                android:id="@+id/bottomNavSlot"
                android:layout_width="match_parent"
                android:layout_height="@dimen/bottom_nav_bar_height"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_bottom_nav_dark"
                android:elevation="8dp"/>

            <!-- fabNotchBackdrop এখন পেজ ব্যাকগ্রাউন্ডের রঙে (bgColor) — বারের রঙে না — যাতে সত্যিকারের
                 "ফাঁকা/হোল" U-কার্ভ নচ তৈরি হয়, বার আর + বাটনের মাঝে ফাঁকা গর্তের মতো দেখায় (কার্ভ ভরাট না) -->
            <View
                android:id="@+id/fabNotchBackdrop"
                android:layout_width="@dimen/bottom_fab_notch_size"
                android:layout_height="@dimen/bottom_fab_notch_size"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="-30dp"
                android:background="@drawable/shape_circle_solid"
                android:elevation="7dp"/>

            <ImageButton
                android:id="@+id/bottomFab"
                android:layout_width="@dimen/bottom_fab_size"
                android:layout_height="@dimen/bottom_fab_size"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="-30dp"
                android:padding="14dp"
                android:background="@drawable/bg_fab_add"
                android:src="@drawable/ic_plus"
                android:contentDescription="@string/add_menu_title"
                android:scaleType="fitCenter"
                android:elevation="10dp"/>
        </FrameLayout>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════
         + বাটন ফ্যান-আউট মেন্যু ওভারলে — পুরো স্ক্রিন জুড়ে, ডিফল্ট GONE।
         টপ পজিশনে fabMenuTop (হেডারের নিচে ডানে) আর বটম পজিশনে fabMenuBottom
         (+ বাটনের উপরে) — যেটা প্রযোজ্য সেটাই ভিজিবল হয়। এখন আইটেমগুলো পাশাপাশি
         (horizontal) সাজানো, বড় আইকন, আর কোডে (openFabMenu) প্রতিটার জন্য আলাদা
         translationY দিয়ে একটা বাঁকানো/আর্ক আকৃতি তৈরি করা হয়।
    ══════════════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/fabMenuOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <View
            android:id="@+id/fabMenuScrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/fabMenuScrim"/>

        <!-- টপ পজিশনের জন্য — হেডারের নিচে, ডানপাশে, পাশাপাশি সাজানো -->
        <LinearLayout
            android:id="@+id/fabMenuTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="148dp"
            android:layout_marginEnd="16dp"
            android:orientation="horizontal"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:visibility="gone"/>

        <!-- বটম পজিশনের জন্য — + বাটনের ঠিক উপরে, কেন্দ্রে, পাশাপাশি বাঁকানো (arc) সাজানো -->
        <LinearLayout
            android:id="@+id/fabMenuBottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="118dp"
            android:orientation="horizontal"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:visibility="gone"/>
    </FrameLayout>
    </FrameLayout>

    <!-- ── প্রোফেশনাল নেভিগেশন ড্রয়ার — হ্যামবার্গার বাটনে ট্যাপ করলে বাম থেকে খোলে ── -->
    <include layout="@layout/nav_drawer_content"/>

</androidx.drawerlayout.widget.DrawerLayout>
