<?xml version="1.0" encoding="utf-8"?>
<!--
    CashLipi — Dashboard container (UI/Navigation upgrade v2)
    ভেতরে থাকে:
      (১) কমপ্যাক্ট ব্র্যান্ড হেডার (টাইটেল-সাইকেল) + Add (+) বাটন — পপ-আপে ৩টি কুইক-অ্যাড অপশন + সেটিং
      (২) ৭-আইকন নেভ বার — সেটিং অনুযায়ী "উপরে" (ডিফল্ট) অথবা "নিচে" পজিশনে বসে (topNavBar ভিউটাই রিপ্যারেন্ট হয়)
      (৩) নিচে পজিশনে থাকলে — bottomNavContainer দেখানো হয়, যেখানে + বাটন কার্ভ করে বারের উপর ভেসে থাকে
      (৪) ViewPager2 — ৭টি Fragment পেজ (সোয়াইপ অন/অফ সেটিং দিয়ে নিয়ন্ত্রিত)
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bgColor">

    <!-- ══════════════════════════════════════════════════════════
         TOP BLOCK — হেডার (+ Add বাটন) + topNavSlot (নেভ বার এখানে বসে যখন পজিশন = উপরে)
    ══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/topBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/topHeaderBg">

        <!-- Compact brand header — TextSwitcher টাইটেল-সাইকেল + Add বাটন -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/top_header_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <TextSwitcher
                android:id="@+id/headerTitleSwitcher"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inAnimation="@anim/slide_in_right"
                android:outAnimation="@anim/slide_out_left" />

            <!-- Add (+) বাটন — ট্যাপ করলে পপ-আপ: আয়-ব্যয় যোগ / দেনা-পাওনা যোগ / সঞ্চয় যোগ / সেটিং -->
            <ImageButton
                android:id="@+id/headerAddBtn"
                android:layout_width="@dimen/header_add_btn_size"
                android:layout_height="@dimen/header_add_btn_size"
                android:layout_marginStart="10dp"
                android:padding="7dp"
                android:background="@drawable/bg_fab_add"
                android:src="@drawable/ic_plus"
                android:contentDescription="@string/add_menu_title"
                android:scaleType="fitCenter"
                android:elevation="3dp"/>
        </LinearLayout>

        <!-- নেভ বার এখানে বসে (পজিশন = "উপরে", ডিফল্ট) — topNavBar রানটাইমে এখানে inflate/attach হয় -->
        <FrameLayout
            android:id="@+id/topNavSlot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- টপ ব্লকের একদম নিচে ডিভাইডার -->
        <View
            android:id="@+id/topBlockDivider"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@drawable/dash_accent_line"/>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════
         ৭টি পেজ — সোয়াইপ (সেটিং দিয়ে অন/অফ) + ট্যাপ নেভিগেশন
    ══════════════════════════════════════════════════════════ -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- ══════════════════════════════════════════════════════════
         BOTTOM BLOCK — পজিশন = "নিচে" হলে দেখানো হয়। bottomNavSlot-এ topNavBar রিপ্যারেন্ট হয়,
         আর মাঝখানে কার্ভ + FAB নেভ বারের উপরে সামান্য ভেসে থাকে (elevation + negative margin)।
    ══════════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone">

        <FrameLayout
            android:id="@+id/bottomNavSlot"
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_nav_bar_height"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_bottom_nav_dark"
            android:elevation="8dp"/>

        <ImageButton
            android:id="@+id/bottomFab"
            android:layout_width="@dimen/bottom_fab_size"
            android:layout_height="@dimen/bottom_fab_size"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="-18dp"
            android:padding="14dp"
            android:background="@drawable/bg_fab_add"
            android:src="@drawable/ic_plus"
            android:contentDescription="@string/add_menu_title"
            android:scaleType="fitCenter"
            android:elevation="10dp"/>
    </FrameLayout>

</LinearLayout>
