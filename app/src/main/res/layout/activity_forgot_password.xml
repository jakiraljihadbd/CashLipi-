<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="@drawable/bg_login_gradient"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="28dp"
            android:paddingTop="56dp"
            android:paddingBottom="32dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔐"
                android:textSize="48sp"
                android:layout_marginBottom="12dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Password রিসেট করুন"
                android:textSize="22sp" android:textStyle="bold" android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📧 আপনার Email-এ Reset Link পাঠানো হবে"
                android:textSize="13sp" android:textColor="#E0E7FF"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp"
                android:background="@drawable/bg_auth_card">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="আপনার Email"
                    android:textSize="12sp" android:textColor="#C7D2FE"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etResetEmail"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="16dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#94A3B8"
                    android:textSize="14sp"
                    android:hint="example@gmail.com"
                    android:inputType="textEmailAddress"
                    android:layout_marginBottom="18dp"/>

                <Button
                    android:id="@+id/btnSendResetEmail"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="✉️ Reset Link পাঠান"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:backgroundTint="#6366F1"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="📬 Link পাঠানোর পর Gmail (Inbox বা Spam) চেক করুন"
                    android:textSize="11sp" android:textColor="#94A3B8"
                    android:gravity="center"
                    android:layout_marginTop="14dp"/>

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="14dp"
                    android:indeterminateTint="#6366F1"
                    android:visibility="gone"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
