<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bkSurface">

    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="100dp">

        <!-- HEADER -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_gdrive"
            android:orientation="vertical"
            android:paddingTop="52dp"
            android:paddingBottom="24dp"
            android:paddingHorizontal="20dp">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Google Drive Backup"
                        android:textColor="@color/bkTextPrimary"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Drive-এ ব্যাকআপ সংরক্ষণ ও পুনরুদ্ধার"
                        android:textColor="@color/bkTextSecondary"
                        android:textSize="12sp"/>
                </LinearLayout>

                <ImageView android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_google_drive"
                    android:alpha="0.9"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ACCOUNT CARD -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardGDriveAccount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/bkCard"
            app:cardElevation="4dp">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Google Account"
                    android:textColor="@color/bkTextPrimary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp"/>

                <!-- Account status -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/card_dark_bg"
                    android:padding="14dp"
                    android:layout_marginBottom="14dp">

                    <LinearLayout android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/circle_gdrive_bg"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="G"
                            android:textColor="@color/bkTextPrimary"
                            android:textSize="20sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">
                        <TextView android:id="@+id/tvGDriveSignInStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" Google Account সংযুক্ত নয়"
                            android:textColor="@color/bkAccentRed"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sign in করুন ব্যাকআপের জন্য"
                            android:textColor="@color/bkTextSecondary"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Sign In button -->
                <Button android:id="@+id/btnGoogleSignIn"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="  Google Sign-In"
                    android:textColor="@color/bkTextPrimary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_gradient_gdrive"
                    android:stateListAnimator="@null"
                    android:layout_marginBottom="8dp"/>

                <!-- Sign Out button -->
                <Button android:id="@+id/btnGoogleSignOut"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="সাইন আউট"
                    android:textColor="@color/bkTextSecondary"
                    android:textSize="13sp"
                    android:background="@drawable/btn_outline_gray"
                    android:stateListAnimator="@null"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- OPTIONS CARD -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardGDriveOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/bkCard"
            app:cardElevation="4dp">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sync Options"
                    android:textColor="@color/bkTextPrimary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp"/>

                <!-- Auto Sync toggle -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Auto Sync"
                            android:textColor="@color/bkTextPrimary"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ডেটা পরিবর্তনে স্বয়ংক্রিয় সিঙ্ক"
                            android:textColor="@color/bkTextSecondary"
                            android:textSize="11sp"/>
                    </LinearLayout>
                    <Switch android:id="@+id/switchGDriveAutoSync"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/bkAccentGoogle"
                        android:trackTint="@color/bkCardInner"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- FOLDER PATH CARD -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardGDrivePath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/bkCard"
            app:cardElevation="4dp">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <LinearLayout android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/circle_gdrive_bg"
                    android:gravity="center">
                    <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/emoji_cloud" android:scaleType="centerInside"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Backup Folder"
                        android:textColor="@color/bkTextPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                    <TextView android:id="@+id/tvDriveFolderPath"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Drive App Data → CashLipi_backup.json"
                        android:textColor="@color/bkAccentGoogle"
                        android:textSize="11sp"
                        android:fontFamily="monospace"/>
                    <TextView android:id="@+id/tvGDriveLastSync"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="এখনো কোনো সিঙ্ক হয়নি"
                        android:textColor="@color/bkTextSecondary"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ACTIONS CARD -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardGDriveActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/bkCard"
            app:cardElevation="4dp">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <TextView android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Actions"
                        android:textColor="@color/bkTextPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                    <ProgressBar android:id="@+id/progressGDriveSync"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:visibility="gone"
                        android:indeterminateTint="@color/colorPrimary"/>
                </LinearLayout>

                <Button android:id="@+id/btnManualUpload"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="  Drive-এ আপলোড করুন"
                    android:textColor="@color/bkTextPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_gradient_gdrive"
                    android:stateListAnimator="@null"
                    android:layout_marginBottom="10dp"/>

                <Button android:id="@+id/btnRestoreFromDrive"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="  Drive থেকে রিস্টোর করুন"
                    android:textColor="@color/bkTextPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_gradient_green"
                    android:stateListAnimator="@null"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
