<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/appBg">

    <LinearLayout android:id="@+id/listHeader" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:background="@drawable/bg_header_ledger"
        android:orientation="vertical" android:paddingTop="14dp"
        android:paddingBottom="20dp" android:paddingHorizontal="18dp"
        android:elevation="6dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="14dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text=" দেনা/পাওনা তালিকা"
                android:textSize="19sp" android:textStyle="bold" android:textColor="@color/white"
                android:fontFamily="sans-serif-medium"/>
            <LinearLayout android:id="@+id/btnAddNew" android:layout_width="38dp" android:layout_height="38dp"
                android:background="@drawable/bg_summary_glass"
                android:gravity="center"
                android:layout_marginStart="12dp"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="+" android:textSize="22sp" android:textStyle="bold"
                    android:textColor="@color/white"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Dena / Pabona quick totals -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="10dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:background="@drawable/bg_summary_glass"
                android:orientation="vertical" android:padding="12dp" android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text=" দেনা" android:textSize="11sp" android:textColor="@color/white"/>
                <TextView android:id="@+id/tvDenaTotal" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="৳ 0"
                    android:textSize="16sp" android:textStyle="bold" android:textColor="@color/white"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:background="@drawable/bg_summary_glass"
                android:orientation="vertical" android:padding="12dp" android:layout_marginStart="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text=" পাওনা" android:textSize="11sp" android:textColor="@color/white"/>
                <TextView android:id="@+id/tvPabonaTotal" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="৳ 0"
                    android:textSize="16sp" android:textStyle="bold" android:textColor="@color/white"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Filtered Summary -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@drawable/bg_summary_glass" android:padding="16dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/tvSummaryTotal" android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="৳ 0" android:textSize="26sp" android:textStyle="bold"
                    android:textColor="@color/white" android:fontFamily="sans-serif-medium"/>
                <TextView android:id="@+id/tvSummaryCount" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0 টি এন্ট্রি"
                    android:layout_marginTop="4dp"
                    android:textSize="12.5sp" android:textColor="@color/white"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Search -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="50dp"
        android:layout_marginHorizontal="16dp" android:layout_marginTop="14dp"
        android:layout_marginBottom="8dp" android:orientation="horizontal"
        android:gravity="center_vertical" android:background="@drawable/bg_search_premium"
        android:paddingStart="14dp" android:paddingEnd="10dp">
        <ImageView android:layout_width="20dp" android:layout_height="20dp"
            android:src="@drawable/ic_search" android:layout_marginEnd="10dp"
            android:alpha="0.7"/>
        <EditText android:id="@+id/etSearch"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:inputType="text" android:hint="খুঁজুন..."
            android:textSize="14sp" android:textColor="@color/searchTextColor"
            android:textColorHint="@color/searchHintColor"
            android:background="@android:color/transparent"
            android:singleLine="true" android:maxLines="1"
            android:imeOptions="actionSearch"
            android:cursorVisible="true"/>
        <ImageView android:id="@+id/ivClearSearch"
            android:layout_width="22dp" android:layout_height="22dp"
            android:src="@drawable/ic_clear" android:layout_marginStart="6dp"
            android:visibility="gone"
            android:alpha="0.6"
            android:padding="2dp"/>
    </LinearLayout>

    <!-- Date Filter Chips (সব/আজ/সপ্তাহ/মাস/বছর) -->
    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:scrollbars="none" android:paddingHorizontal="16dp" android:layout_marginBottom="8dp">
        <LinearLayout android:id="@+id/chipRowDate" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:orientation="horizontal"/>
    </HorizontalScrollView>

    <!-- Filter Chips — সব/দেনা/পাওনা | বাকি/পরিশোধ একটি row এ -->
    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:scrollbars="none" android:paddingHorizontal="16dp" android:layout_marginBottom="10dp">
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">

            <TextView android:id="@+id/chipAll" android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="সব" android:textSize="12sp" android:gravity="center"
                android:paddingHorizontal="16dp" android:background="@drawable/bg_chip_selected"
                android:textColor="@color/white" android:layout_marginEnd="7dp"
                android:textStyle="bold" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/chipDena" android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="দেনা" android:textSize="12sp" android:gravity="center"
                android:paddingHorizontal="16dp" android:background="@drawable/bg_chip_unselected"
                android:textColor="@color/chipUnselectedText" android:layout_marginEnd="7dp"
                android:textStyle="bold" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/chipPabona" android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="পাওনা" android:textSize="12sp" android:gravity="center"
                android:paddingHorizontal="16dp" android:background="@drawable/bg_chip_unselected"
                android:textColor="@color/chipUnselectedText" android:layout_marginEnd="12dp"
                android:textStyle="bold" android:clickable="true" android:focusable="true"/>

            <View android:layout_width="1.5dp" android:layout_height="20dp"
                android:background="@color/borderColor" android:layout_marginEnd="12dp"/>

            <TextView android:id="@+id/chipUnpaid" android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="বাকি" android:textSize="12sp" android:gravity="center"
                android:paddingHorizontal="16dp" android:background="@drawable/bg_chip_unselected"
                android:textColor="@color/chipUnselectedText" android:layout_marginEnd="7dp"
                android:textStyle="bold" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/chipPaid" android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="পরিশোধ" android:textSize="12sp" android:gravity="center"
                android:paddingHorizontal="16dp" android:background="@drawable/bg_chip_unselected"
                android:textColor="@color/chipUnselectedText"
                android:textStyle="bold" android:clickable="true" android:focusable="true"/>

        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvList"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:paddingHorizontal="16dp" android:paddingTop="4dp" android:paddingBottom="12dp"
        android:clipToPadding="false" android:overScrollMode="never"/>

    <LinearLayout android:id="@+id/emptyState" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:orientation="vertical" android:gravity="center" android:visibility="gone">
        <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:src="@drawable/emoji_empty_mailbox" android:scaleType="centerInside" android:layout_marginBottom="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="কোনো দেনা-পাওনা নেই" android:textSize="16sp"
            android:textColor="@color/textPrimary" android:textStyle="bold"/>
    </LinearLayout>
</LinearLayout>
