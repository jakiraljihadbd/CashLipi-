<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Gradient bg (matches login screen brand style) -->
    <View android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="@drawable/bg_login_gradient"/>

    <!-- Top deco circle -->
    <View android:layout_width="260dp" android:layout_height="260dp"
        android:background="@drawable/bg_login_circle_top"
        android:layout_gravity="top|end"
        android:translationX="70dp" android:translationY="-70dp" android:alpha="0.18"/>

    <!-- Bottom deco circle -->
    <View android:layout_width="200dp" android:layout_height="200dp"
        android:background="@drawable/bg_login_circle_bottom"
        android:layout_gravity="bottom|start"
        android:translationX="-50dp" android:translationY="50dp" android:alpha="0.14"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:overScrollMode="never" android:fillViewport="true">

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="center"
        android:paddingHorizontal="28dp" android:paddingVertical="20dp">

        <!-- App icon — perfectly circular avatar, no square/black background -->
        <FrameLayout android:layout_width="80dp" android:layout_height="80dp"
            android:layout_marginBottom="12dp">
            <View android:layout_width="80dp" android:layout_height="80dp"
                android:background="@drawable/bg_login_logo_glow"/>
            <androidx.cardview.widget.CardView
                android:layout_width="60dp" android:layout_height="60dp"
                android:layout_gravity="center"
                app:cardCornerRadius="30dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">
                <ImageView
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:src="@drawable/logo_splash"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/app_name"/>
            </androidx.cardview.widget.CardView>
        </FrameLayout>

        <TextView android:id="@+id/tvLockTitle"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="CashLipi ক্যাশলিপি" android:textSize="20sp"
            android:textStyle="bold" android:textColor="@color/white"
            android:layout_marginBottom="4dp"/>

        <TextView android:id="@+id/tvLockSubtitle"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="আনলক করুন" android:textSize="12sp"
            android:textColor="#C7D2FE" android:layout_marginBottom="22dp"/>

        <!-- PIN dots -->
        <LinearLayout android:id="@+id/layoutPinInput"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center">

            <LinearLayout
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <View android:id="@+id/dotPin1" android:layout_width="16dp" android:layout_height="16dp"
                    android:layout_marginHorizontal="9dp" android:background="@drawable/shape_pin_dot_empty"/>
                <View android:id="@+id/dotPin2" android:layout_width="16dp" android:layout_height="16dp"
                    android:layout_marginHorizontal="9dp" android:background="@drawable/shape_pin_dot_empty"/>
                <View android:id="@+id/dotPin3" android:layout_width="16dp" android:layout_height="16dp"
                    android:layout_marginHorizontal="9dp" android:background="@drawable/shape_pin_dot_empty"/>
                <View android:id="@+id/dotPin4" android:layout_width="16dp" android:layout_height="16dp"
                    android:layout_marginHorizontal="9dp" android:background="@drawable/shape_pin_dot_empty"/>
            </LinearLayout>

            <!-- Forgot PIN -->
            <TextView android:id="@+id/tvForgotPin"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="PIN ভুলে গেছেন?" android:textSize="12sp"
                android:textColor="#E0E7FF" android:textStyle="bold"
                android:padding="8dp" android:clickable="true" android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>

        <!-- Pattern input -->
        <LinearLayout android:id="@+id/layoutPatternInput"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center"
            android:visibility="gone">
            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                app:cardCornerRadius="20dp" app:cardElevation="6dp"
                app:cardBackgroundColor="#14FFFFFF">
                <com.jrappspot.cashlipi.views.PatternLockView
                    android:id="@+id/patternLockView"
                    android:layout_width="220dp" android:layout_height="220dp"
                    android:layout_margin="12dp"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Error pill -->
        <TextView android:id="@+id/tvLockError"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:background="@drawable/bg_lock_error_pill"
            android:paddingHorizontal="16dp" android:paddingVertical="8dp"
            android:textColor="#FCA5A5" android:textSize="12sp"
            android:textStyle="bold" android:layout_marginTop="12dp"
            android:visibility="gone"/>

        <!-- Custom numeric keypad (replaces the system keyboard) -->
        <GridLayout android:id="@+id/keypad"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:columnCount="3" android:rowCount="4"
            android:layout_marginTop="18dp">

            <TextView android:id="@+id/keyPad1" style="@style/LockKeypadKey" android:text="1"/>
            <TextView android:id="@+id/keyPad2" style="@style/LockKeypadKey" android:text="2"/>
            <TextView android:id="@+id/keyPad3" style="@style/LockKeypadKey" android:text="3"/>

            <TextView android:id="@+id/keyPad4" style="@style/LockKeypadKey" android:text="4"/>
            <TextView android:id="@+id/keyPad5" style="@style/LockKeypadKey" android:text="5"/>
            <TextView android:id="@+id/keyPad6" style="@style/LockKeypadKey" android:text="6"/>

            <TextView android:id="@+id/keyPad7" style="@style/LockKeypadKey" android:text="7"/>
            <TextView android:id="@+id/keyPad8" style="@style/LockKeypadKey" android:text="8"/>
            <TextView android:id="@+id/keyPad9" style="@style/LockKeypadKey" android:text="9"/>

            <View android:layout_width="60dp" android:layout_height="60dp"
                android:layout_margin="6dp"/>
            <TextView android:id="@+id/keyPad0" style="@style/LockKeypadKey" android:text="0"/>
            <TextView android:id="@+id/keyBackspace" style="@style/LockKeypadKey"
                android:text="⌫" android:textSize="20sp"/>

        </GridLayout>

        <!-- Fingerprint — tap to trigger biometric auth (no auto-popup on screen open) -->
        <LinearLayout android:id="@+id/layoutFingerprint"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center"
            android:layout_marginTop="20dp" android:visibility="gone">

            <FrameLayout
                android:layout_width="72dp" android:layout_height="72dp">

                <!-- soft pulsing ring, animated in code for a premium breathing effect -->
                <View android:id="@+id/fingerprintPulseRing"
                    android:layout_width="72dp" android:layout_height="72dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_fingerprint_pulse_ring"/>

                <!-- glass card: translucent fill + hairline stroke + soft shadow + ripple -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="56dp" android:layout_height="56dp"
                    android:layout_gravity="center"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="6dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/lockGlassCardStroke"
                    app:cardBackgroundColor="@color/lockGlassCardBg"
                    app:rippleColor="@color/colorPrimaryLight">

                    <ImageView android:id="@+id/btnFingerprint"
                        android:layout_width="match_parent" android:layout_height="match_parent"
                        android:src="@drawable/ic_fingerprint"
                        android:padding="15dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true" android:focusable="true"
                        android:contentDescription="ফিঙ্গারপ্রিন্ট দিয়ে আনলক করুন"/>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ফিঙ্গারপ্রিন্ট দিয়ে আনলক করুন" android:textSize="10sp"
                android:textColor="#C7D2FE" android:layout_marginTop="8dp"/>
        </LinearLayout>

    </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
