<?xml version="1.0" encoding="utf-8"?>
<!-- নেভিগেশন মেন্যু — A-to-Z কাস্টমাইজেশন পেজ (আগে পপ-আপ ডায়ালগ ছিল, এখন পূর্ণ পেজ)।
     প্রতিটা কন্ট্রোল ট্যাপ করা মাত্র DatabaseManager-এ সেভ হয় + refreshPreview() দিয়ে
     লাইভ প্রিভিউ আপডেট হয়। পেজ থেকে বের হলে (finish) DashboardActivity.onResume()
     স্বয়ংক্রিয়ভাবে applyNavCustomization() চালায় — আলাদা করে অ্যাপ থেকে বের হওয়া লাগে না। -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bgColor">

    <!-- হেডার -->
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_header_generic" android:orientation="horizontal"
        android:gravity="center_vertical" android:paddingTop="12dp"
        android:paddingBottom="14dp" android:paddingHorizontal="10dp">

        <ImageButton android:id="@+id/btnNavBack"
            android:layout_width="40dp" android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back" app:tint="@color/white"
            android:contentDescription="@string/nav_done_btn"/>

        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="@string/nav_customize_title" android:textSize="18sp"
            android:textStyle="bold" android:textColor="@color/white"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_customize_subtitle"
                android:textSize="12sp" android:textColor="@color/textSecondary"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_live_apply_hint"
                android:textSize="11sp" android:textColor="@color/colorPrimary"
                android:layout_marginBottom="16dp"/>

            <!-- ── লাইভ প্রিভিউ কার্ড ── -->
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_live_preview_title"
                android:textSize="13sp" android:textStyle="bold"
                android:textColor="@color/colorPrimary" android:layout_marginBottom="8dp"/>

            <FrameLayout
                android:id="@+id/previewCard"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/bg_card_white"
                android:padding="10dp" android:minHeight="90dp"
                android:layout_marginBottom="20dp">

                <FrameLayout
                    android:id="@+id/previewBarSlot"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"/>
            </FrameLayout>

            <!-- ── স্টাইল প্রিসেট (৭টা) ── -->
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_style_section_title"
                android:textSize="13sp" android:textStyle="bold"
                android:textColor="@color/colorPrimary" android:layout_marginBottom="10dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:scrollbars="none" android:layout_marginBottom="20dp">

                <LinearLayout
                    android:id="@+id/styleCardsContainer"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal"/>
            </HorizontalScrollView>

            <!-- ── আইকন সাইজ ── -->
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_icon_size_label"
                android:textSize="13sp" android:textStyle="bold"
                android:textColor="@color/colorPrimary" android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent" android:layout_height="44dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_login_toggle_group"
                android:padding="3dp" android:layout_marginBottom="18dp">

                <TextView android:id="@+id/btnSizeLarge"
                    android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:gravity="center"
                    android:text="@string/nav_icon_size_large"
                    android:textSize="13sp" android:textColor="@color/white"
                    android:background="@drawable/bg_login_toggle_selected"
                    android:clickable="true" android:focusable="true"/>

                <TextView android:id="@+id/btnSizeSmall"
                    android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:gravity="center"
                    android:text="@string/nav_icon_size_small"
                    android:textSize="13sp" android:textColor="@color/textSecondary"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <!-- ── ব্যাকগ্রাউন্ড রং ── -->
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_bg_color_label"
                android:textSize="13sp" android:textStyle="bold"
                android:textColor="@color/colorPrimary" android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:id="@+id/swatchContainer"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center"
                android:layout_marginBottom="18dp">

                <FrameLayout android:id="@+id/swatchWrapNavy" style="@style/NavSwatchWrap">
                    <View android:id="@+id/swatchNavy" style="@style/NavSwatchDot"
                        android:backgroundTint="@color/navSwatchNavy" android:tag="#0F1B2E"/>
                </FrameLayout>
                <FrameLayout android:id="@+id/swatchWrapIndigo" style="@style/NavSwatchWrap">
                    <View android:id="@+id/swatchIndigo" style="@style/NavSwatchDot"
                        android:backgroundTint="@color/navSwatchIndigo" android:tag="#4F46E5"/>
                </FrameLayout>
                <FrameLayout android:id="@+id/swatchWrapPurple" style="@style/NavSwatchWrap">
                    <View android:id="@+id/swatchPurple" style="@style/NavSwatchDot"
                        android:backgroundTint="@color/navSwatchPurple" android:tag="#7C3AED"/>
                </FrameLayout>
                <FrameLayout android:id="@+id/swatchWrapTeal" style="@style/NavSwatchWrap">
                    <View android:id="@+id/swatchTeal" style="@style/NavSwatchDot"
                        android:backgroundTint="@color/navSwatchTeal" android:tag="#0D9488"/>
                </FrameLayout>
                <FrameLayout android:id="@+id/swatchWrapGreen" style="@style/NavSwatchWrap">
                    <View android:id="@+id/swatchGreen" style="@style/NavSwatchDot"
                        android:backgroundTint="@color/navSwatchGreen" android:tag="#059669"/>
                </FrameLayout>
                <FrameLayout android:id="@+id/swatchWrapOrange" style="@style/NavSwatchWrap">
                    <View android:id="@+id/swatchOrange" style="@style/NavSwatchDot"
                        android:backgroundTint="@color/navSwatchOrange" android:tag="#EA580C"/>
                </FrameLayout>
                <FrameLayout android:id="@+id/swatchWrapPink" style="@style/NavSwatchWrap">
                    <View android:id="@+id/swatchPink" style="@style/NavSwatchDot"
                        android:backgroundTint="@color/navSwatchPink" android:tag="#DB2777"/>
                </FrameLayout>
                <FrameLayout android:id="@+id/swatchWrapCharcoal" style="@style/NavSwatchWrap">
                    <View android:id="@+id/swatchCharcoal" style="@style/NavSwatchDot"
                        android:backgroundTint="@color/navSwatchCharcoal" android:tag="#1F2937"/>
                </FrameLayout>
            </LinearLayout>

            <!-- ── পজিশন ── -->
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_position_label"
                android:textSize="13sp" android:textStyle="bold"
                android:textColor="@color/colorPrimary" android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent" android:layout_height="44dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_login_toggle_group"
                android:padding="3dp" android:layout_marginBottom="18dp">

                <TextView android:id="@+id/btnPosTop"
                    android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:gravity="center"
                    android:text="@string/nav_position_top"
                    android:textSize="13sp" android:textColor="@color/white"
                    android:background="@drawable/bg_login_toggle_selected"
                    android:clickable="true" android:focusable="true"/>

                <TextView android:id="@+id/btnPosBottom"
                    android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:gravity="center"
                    android:text="@string/nav_position_bottom"
                    android:textSize="13sp" android:textColor="@color/textSecondary"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <!-- ── সোয়াইপ ── -->
            <LinearLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/nav_swipe_label"
                    android:textSize="14sp" android:textColor="@color/textPrimary"/>

                <Switch android:id="@+id/switchNavSwipe"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <Button android:id="@+id/btnNavDone"
                android:layout_width="match_parent" android:layout_height="@dimen/btn_height"
                android:text="@string/nav_done_btn"
                android:textColor="@color/white" android:textAllCaps="false"
                android:background="@drawable/btn_gradient_primary"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
