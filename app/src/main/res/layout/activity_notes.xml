<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bgColor">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_header_generic" android:orientation="horizontal"
        android:gravity="center_vertical" android:paddingTop="12dp"
        android:paddingBottom="14dp" android:paddingHorizontal="16dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text=" নোট"
            android:textSize="18sp" android:textStyle="bold" android:textColor="@color/white"/>
        <Button android:id="@+id/btnAddNote"
            android:layout_width="wrap_content" android:layout_height="38dp"
            android:text="+ নতুন" android:textSize="12sp" android:textColor="@color/white"
            android:background="@drawable/bg_header_glass_pill" android:paddingHorizontal="12dp"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="50dp"
        android:layout_marginHorizontal="12dp" android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp" android:orientation="horizontal"
        android:gravity="center_vertical" android:background="@drawable/bg_search_premium"
        android:paddingStart="14dp" android:paddingEnd="10dp">
        <ImageView android:layout_width="20dp" android:layout_height="20dp"
            android:src="@drawable/ic_search" android:layout_marginEnd="10dp"
            android:alpha="0.7"/>
        <EditText android:id="@+id/etSearch"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:inputType="text" android:hint="নোট খুঁজুন..."
            android:textSize="14sp" android:textColor="@color/searchTextColor"
            android:textColorHint="@color/searchHintColor"
            android:background="@android:color/transparent"
            android:singleLine="true" android:maxLines="1"
            android:imeOptions="actionSearch"
            android:cursorVisible="true"/>
        <ImageView android:id="@+id/ivClearSearch"
            android:layout_width="22dp" android:layout_height="22dp"
            android:src="@drawable/ic_clear" android:layout_marginStart="6dp"
            android:visibility="gone"
            android:alpha="0.6"
            android:padding="2dp"/>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvNotes"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:paddingHorizontal="12dp"
        android:clipToPadding="false" android:overScrollMode="never"/>
    <LinearLayout android:id="@+id/emptyState" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:orientation="vertical" android:gravity="center" android:visibility="gone">
        <ImageView android:layout_width="64dp" android:layout_height="64dp" android:src="@drawable/emoji_memo" android:scaleType="centerInside" android:layout_marginBottom="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="কোনো নোট নেই" android:textSize="16sp"
            android:textColor="@color/textSecondary" android:textStyle="bold"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="উপরের + বাটন থেকে নোট যোগ করুন"
            android:textSize="12sp" android:textColor="@color/textHint" android:layout_marginTop="6dp"/>
    </LinearLayout>
</LinearLayout>
