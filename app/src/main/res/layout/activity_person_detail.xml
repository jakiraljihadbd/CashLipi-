<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bgColor">

    <!-- কমপ্যাক্ট হেডার -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/cardBg"
        android:paddingStart="2dp"
        android:paddingEnd="8dp"
        android:paddingVertical="8dp"
        android:elevation="3dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/textPrimary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>

        <!-- ছবি + নাম — ছবির উপরের কিনারার সাথে নাম মিলিয়ে রাখতে গ্র্যাভিটি টপ -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:orientation="horizontal"
            android:gravity="top">

            <FrameLayout
                android:layout_width="46dp"
                android:layout_height="46dp">

                <ImageView
                    android:id="@+id/ivDetailPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"/>

                <LinearLayout
                    android:id="@+id/avatarInitialDetail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_avatar_circle_1"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvDetailInitial"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="?"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"/>
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvDetailName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:maxLines="1"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/tvDetailRelationBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="7dp"
                        android:background="@drawable/bg_relation_chip"
                        android:paddingHorizontal="9dp"
                        android:paddingVertical="1.5dp"
                        android:textSize="10.5sp"
                        android:textStyle="bold"
                        android:textColor="#B3105A"
                        android:visibility="gone"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvDetailPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:textSize="12.5sp"
                    android:textColor="@color/textSecondary"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ডান পাশে: হোয়াটসঅ্যাপ, কল, মেইল, তারপর ⋮ মেনু (এডিট/মুছুন) -->
        <ImageView
            android:id="@+id/btnWhatsapp"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:padding="9dp"
            android:src="@drawable/ic_whatsapp"
            app:tint="#25D366"
            android:background="@drawable/bg_action_circle_whatsapp"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/btnCall"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="4dp"
            android:padding="9dp"
            android:src="@drawable/ic_call_filled"
            app:tint="#10B981"
            android:background="@drawable/bg_action_circle_call"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/btnMail"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="4dp"
            android:padding="9dp"
            android:src="@drawable/ic_mail"
            app:tint="#3B82F6"
            android:background="@drawable/bg_action_circle_mail"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/btnMorePerson"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="2dp"
            android:padding="8dp"
            android:src="@drawable/ic_more_vert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- হিরো ব্যালেন্স কার্ড — নিট হিসাব (আপনি দিবেন/পাবেন) + মোট লেনদেন, কম-রাউন্ড প্রিমিয়াম লুক -->
    <androidx.cardview.widget.CardView
        android:id="@+id/heroCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="5dp"
        app:cardPreventCornerOverlap="false"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/heroCardInner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/card_receivable_summary">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_nav_dena_pawna"
                    app:tint="@color/white"
                    android:alpha="0.85"
                    android:layout_marginEnd="7dp"/>

                <TextView
                    android:id="@+id/tvHeroLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="12.5sp"
                    android:textColor="@color/white"
                    android:alpha="0.92"/>

                <ImageView
                    android:id="@+id/btnShareStatement"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_share"
                    app:tint="@color/white"
                    android:background="@drawable/bg_summary_glass"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvHeroAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/white"/>

            <TextView
                android:id="@+id/tvHeroSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textSize="11.5sp"
                android:textColor="@color/white"
                android:alpha="0.88"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- সার্চ + ফিল্টার চিপ + ভিউ-বদল আইকন — এক লাইনে, কম্প্যাক্ট -->
    <LinearLayout
        android:id="@+id/personToolsRow"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/personSearchBox"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_search_premium"
            android:paddingStart="12dp"
            android:paddingEnd="8dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_search"
                android:layout_marginEnd="8dp"
                android:alpha="0.7"/>

            <EditText
                android:id="@+id/etPersonLedgerSearch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="text"
                android:hint="খুঁজুন..."
                android:textSize="12.5sp"
                android:textColor="@color/searchTextColor"
                android:textColorHint="@color/searchHintColor"
                android:background="@android:color/transparent"
                android:singleLine="true"
                android:maxLines="1"
                android:imeOptions="actionSearch"/>

            <ImageView
                android:id="@+id/ivClearPersonSearch"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_clear"
                android:layout_marginStart="4dp"
                android:visibility="gone"
                android:alpha="0.6"
                android:padding="2dp"/>
        </LinearLayout>

        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="6dp">

            <ImageView
                android:id="@+id/btnPersonFilter"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="8dp"
                android:src="@drawable/ic_filter"
                app:tint="@color/textPrimary"
                android:background="@drawable/bg_card_white"
                android:clickable="true"
                android:focusable="true"/>

            <View
                android:id="@+id/personFilterActiveDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_gravity="top|end"
                android:layout_margin="2dp"
                android:background="@drawable/dot_active"
                android:visibility="gone"/>
        </FrameLayout>

        <ImageView
            android:id="@+id/btnToggleView"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="6dp"
            android:padding="8dp"
            android:src="@drawable/ic_view_grid"
            app:tint="@color/textPrimary"
            android:background="@drawable/bg_card_white"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/btnExportPdf"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="6dp"
            android:padding="8dp"
            android:src="@drawable/ic_pdf"
            app:tint="@color/textPrimary"
            android:background="@drawable/bg_card_white"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- কার্ড-লিস্ট ভিউ (ডিফল্ট) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPersonLedger"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="6dp"
        android:visibility="gone"/>

    <!-- ছক (টেবিল) ভিউ — বিবরণ/দেনা/পাওনা কলাম, নিচে মোট সারি -->
    <LinearLayout
        android:id="@+id/tableViewContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="9dp"
            android:background="@drawable/bg_table_header_grid">

            <!-- সারির বাম পাশের ৩dp রঙিন বার-এর সাথে কলাম-অ্যালাইনমেন্ট মেলাতে একই চওড়ার
                 অদৃশ্য স্পেসার — এটা না থাকলে হেডারের "|" দাগ আর সারির ভেতরের দাগ ৩dp
                 এদিক-ওদিক হয়ে যেত। -->
            <View
                android:layout_width="3dp"
                android:layout_height="match_parent"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:paddingStart="11dp"
                android:text="বিবরণ"
                android:textSize="11.5sp"
                android:textStyle="bold"
                android:textColor="@color/textSecondary"/>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/dividerColor"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingHorizontal="8dp"
                android:text="দেনা"
                android:gravity="end"
                android:textSize="11.5sp"
                android:textStyle="bold"
                android:textColor="@color/denaColor"/>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/dividerColor"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingHorizontal="8dp"
                android:text="পাওনা"
                android:gravity="end"
                android:textSize="11.5sp"
                android:textStyle="bold"
                android:textColor="@color/pabonaColor"/>
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never">

            <LinearLayout
                android:id="@+id/tableRowsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:background="@color/dialogFieldBg"
            android:elevation="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="মোট"
                android:textSize="12.5sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"/>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/dividerColor"/>

            <TextView
                android:id="@+id/tvTableTotalDena"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingHorizontal="8dp"
                android:gravity="end"
                android:textSize="12.5sp"
                android:textStyle="bold"
                android:textColor="@color/denaColor"/>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/dividerColor"/>

            <TextView
                android:id="@+id/tvTableTotalPabona"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingHorizontal="8dp"
                android:gravity="end"
                android:textSize="12.5sp"
                android:textStyle="bold"
                android:textColor="@color/pabonaColor"/>
        </LinearLayout>
    </LinearLayout>

    <!-- খালি অবস্থা — কোনো লেনদেন নেই (বা সার্চ/ফিল্টারে কিছু মিলছে না) -->
    <LinearLayout
        android:id="@+id/emptyLedgerState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="40dp">

        <ImageView
            android:id="@+id/ivEmptyLedger"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_nav_dena_pawna"
            android:alpha="0.35"
            android:layout_marginBottom="14dp"/>

        <TextView
            android:id="@+id/tvEmptyLedgerTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="এই ব্যক্তির সাথে এখনও কোনো লেনদেন যোগ করা হয়নি"
            android:textSize="14.5sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvEmptyLedgerSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="নিচের বাটনে চেপে প্রথম দেনা বা পাওনা যোগ করুন"
            android:textSize="12.5sp"
            android:textColor="@color/textSecondary"
            android:gravity="center"/>
    </LinearLayout>

    <!-- নিচে: পাওনা (+) / দেনা (-) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/cardBg"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:elevation="6dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAddPelam"
            android:layout_width="0dp"
            android:layout_height="@dimen/btn_height"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text=" + পাওনা"
            android:textSize="14.5sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:backgroundTint="@null"
            android:background="@drawable/bg_type_active_pabona"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAddDilam"
            android:layout_width="0dp"
            android:layout_height="@dimen/btn_height"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text=" − দেনা"
            android:textSize="14.5sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:backgroundTint="@null"
            android:background="@drawable/bg_type_active_dena"/>
    </LinearLayout>

</LinearLayout>
