<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bgColor">

    <!-- কমপ্যাক্ট হেডার -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/cardBg"
        android:paddingStart="2dp"
        android:paddingEnd="8dp"
        android:paddingVertical="8dp"
        android:elevation="3dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>

        <!-- ছবি + নাম — ছবির উপরের কিনারার সাথে নাম মিলিয়ে রাখতে গ্র্যাভিটি টপ -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:orientation="horizontal"
            android:gravity="top">

            <FrameLayout
                android:layout_width="46dp"
                android:layout_height="46dp">

                <ImageView
                    android:id="@+id/ivDetailPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"/>

                <LinearLayout
                    android:id="@+id/avatarInitialDetail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_avatar_circle_1"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvDetailInitial"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="?"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"/>
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvDetailName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:maxLines="1"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/tvDetailRelationBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="7dp"
                        android:background="@drawable/bg_relation_chip"
                        android:paddingHorizontal="9dp"
                        android:paddingVertical="1.5dp"
                        android:textSize="10.5sp"
                        android:textStyle="bold"
                        android:textColor="#B3105A"
                        android:visibility="gone"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvDetailPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:textSize="12.5sp"
                    android:textColor="@color/textSecondary"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ডান পাশে: হোয়াটসঅ্যাপ, কল, মেইল, তারপর ⋮ মেনু (এডিট/মুছুন) -->
        <ImageView
            android:id="@+id/btnWhatsapp"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:padding="9dp"
            android:src="@drawable/ic_whatsapp"
            app:tint="#25D366"
            android:background="@drawable/bg_action_circle_whatsapp"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/btnCall"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="4dp"
            android:padding="9dp"
            android:src="@drawable/ic_call_filled"
            app:tint="#10B981"
            android:background="@drawable/bg_action_circle_call"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/btnMail"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="4dp"
            android:padding="9dp"
            android:src="@drawable/ic_mail"
            app:tint="#3B82F6"
            android:background="@drawable/bg_action_circle_mail"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/btnMorePerson"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="2dp"
            android:padding="8dp"
            android:src="@drawable/ic_more_vert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- স্ক্রল-না-হওয়া টপ ব্লক: হিরো ব্যালেন্স কার্ড + সার্চ + ফিল্টার চিপ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- হিরো ব্যালেন্স কার্ড — নিট হিসাব + মোট পেলাম/দিলাম গ্লাস চিপ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/heroCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp"
            app:cardPreventCornerOverlap="false"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/heroCardInner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="@drawable/card_receivable_summary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvHeroLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12.5sp"
                            android:textColor="@color/white"
                            android:alpha="0.9"/>

                        <TextView
                            android:id="@+id/tvHeroAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:src="@drawable/ic_nav_dena_pawna"
                        app:tint="@color/white"
                        android:alpha="0.85"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:paddingVertical="8dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_summary_glass">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="মোট পেলাম"
                            android:textSize="11sp"
                            android:textColor="@color/white"
                            android:alpha="0.88"/>

                        <TextView
                            android:id="@+id/tvHeroTotalGot"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textSize="14.5sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:paddingVertical="8dp"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_summary_glass">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="মোট দিলাম"
                            android:textSize="11sp"
                            android:textColor="@color/white"
                            android:alpha="0.88"/>

                        <TextView
                            android:id="@+id/tvHeroTotalGave"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textSize="14.5sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:id="@+id/tvHeroSub"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="11sp"
                        android:textColor="@color/white"
                        android:alpha="0.85"/>

                    <ImageView
                        android:id="@+id/btnShareStatement"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:padding="6dp"
                        android:src="@drawable/ic_share"
                        app:tint="@color/white"
                        android:background="@drawable/bg_summary_glass"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- সার্চ — নোট/কারণ অনুযায়ী খুঁজুন -->
        <LinearLayout
            android:id="@+id/personSearchBox"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_search_premium"
            android:paddingStart="14dp"
            android:paddingEnd="10dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search"
                android:layout_marginEnd="10dp"
                android:alpha="0.7"/>

            <EditText
                android:id="@+id/etPersonLedgerSearch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="text"
                android:hint="নোট বা কারণ খুঁজুন..."
                android:textSize="13.5sp"
                android:textColor="@color/searchTextColor"
                android:textColorHint="@color/searchHintColor"
                android:background="@android:color/transparent"
                android:singleLine="true"
                android:maxLines="1"
                android:imeOptions="actionSearch"/>

            <ImageView
                android:id="@+id/ivClearPersonSearch"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_clear"
                android:layout_marginStart="6dp"
                android:visibility="gone"
                android:alpha="0.6"
                android:padding="2dp"/>
        </LinearLayout>

        <!-- ফিল্টার চিপ — সব / অপরিশোধিত / পরিশোধিত -->
        <HorizontalScrollView
            android:id="@+id/personFilterScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/chipPersonAll"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="সব"
                    android:textSize="11.5sp"
                    android:gravity="center"
                    android:paddingHorizontal="15dp"
                    android:background="@drawable/bg_chip_selected"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:layout_marginEnd="7dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/chipPersonUnpaid"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="অপরিশোধিত"
                    android:textSize="11.5sp"
                    android:gravity="center"
                    android:paddingHorizontal="15dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:textColor="@color/chipUnselectedText"
                    android:textStyle="bold"
                    android:layout_marginEnd="7dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/chipPersonPaid"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="পরিশোধিত"
                    android:textSize="11.5sp"
                    android:gravity="center"
                    android:paddingHorizontal="15dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:textColor="@color/chipUnselectedText"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- লেনদেন তালিকা (তারিখ অনুযায়ী গ্রুপ করা) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPersonLedger"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="6dp"
        android:visibility="gone"/>

    <!-- খালি অবস্থা — কোনো লেনদেন নেই (বা সার্চ/ফিল্টারে কিছু মিলছে না) -->
    <LinearLayout
        android:id="@+id/emptyLedgerState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="40dp">

        <ImageView
            android:id="@+id/ivEmptyLedger"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_nav_dena_pawna"
            android:alpha="0.35"
            android:layout_marginBottom="14dp"/>

        <TextView
            android:id="@+id/tvEmptyLedgerTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="এই ব্যক্তির সাথে এখনও কোনো লেনদেন যোগ করা হয়নি"
            android:textSize="14.5sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvEmptyLedgerSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="নিচের বাটনে চেপে প্রথম দিলাম বা পেলাম যোগ করুন"
            android:textSize="12.5sp"
            android:textColor="@color/textSecondary"
            android:gravity="center"/>
    </LinearLayout>

    <!-- নিচে: পেলাম (পাওনা যোগ) / দিলাম (দেনা যোগ) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/cardBg"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:elevation="6dp">

        <Button
            android:id="@+id/btnAddPelam"
            android:layout_width="0dp"
            android:layout_height="@dimen/btn_height"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text=" পেলাম"
            android:textSize="14.5sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:background="@drawable/bg_type_active_pabona"/>

        <Button
            android:id="@+id/btnAddDilam"
            android:layout_width="0dp"
            android:layout_height="@dimen/btn_height"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text=" দিলাম"
            android:textSize="14.5sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:background="@drawable/bg_type_active_dena"/>
    </LinearLayout>

</LinearLayout>
