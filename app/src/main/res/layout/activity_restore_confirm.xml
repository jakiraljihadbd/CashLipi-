<?xml version="1.0" encoding="utf-8"?>
<!-- activity_restore_confirm.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bkSurface"
    android:gravity="center">

    <!-- Confirm Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="@color/bkCard"
        app:cardElevation="12dp">

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp">

            <!-- Animated Icon -->
            <ImageView android:id="@+id/ivRestoreIcon"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_restore_shield"
                android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Restore Backup?"
                android:textColor="@color/bkTextPrimary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="বর্তমান ডেটা নির্বাচিত ব্যাকআপ দিয়ে প্রতিস্থাপিত হবে।"
                android:textColor="@color/bkTextSecondary"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <!-- Preview grid -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_dark_bg"
                android:padding="14dp"
                android:layout_marginBottom="24dp">

                <LinearLayout android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="আয়"
                        android:textColor="@color/bkTextSecondary"
                        android:textSize="11sp"/>
                    <TextView android:id="@+id/tvConfirmIncome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="৳ 0"
                        android:textColor="@color/bkAccentGreen"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ব্যয়"
                        android:textColor="@color/bkTextSecondary"
                        android:textSize="11sp"/>
                    <TextView android:id="@+id/tvConfirmExpense"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="৳ 0"
                        android:textColor="@color/bkAccentRed"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="দেনা"
                        android:textColor="@color/bkTextSecondary"
                        android:textSize="11sp"/>
                    <TextView android:id="@+id/tvConfirmDebt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 টি"
                        android:textColor="@color/bkAccentOrange"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="পাওনা"
                        android:textColor="@color/bkTextSecondary"
                        android:textSize="11sp"/>
                    <TextView android:id="@+id/tvConfirmReceivable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 টি"
                        android:textColor="@color/bkAccentBlue"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Action buttons -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button android:id="@+id/btnCancelRestore"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="বাতিল"
                    android:textColor="@color/bkTextSecondary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_outline_gray"
                    android:stateListAnimator="@null"/>

                <Button android:id="@+id/btnConfirmRestore"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Restore"
                    android:textColor="@color/bkTextPrimary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_gradient_red"
                    android:stateListAnimator="@null"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
