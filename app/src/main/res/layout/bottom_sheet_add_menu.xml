<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/cardBg"
    android:paddingTop="10dp"
    android:paddingBottom="20dp">

    <View
        android:layout_width="40dp" android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_drag_handle"/>

    <TextView
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginStart="20dp" android:layout_marginBottom="10dp"
        android:text="@string/add_menu_title"
        android:textSize="15sp" android:textStyle="bold"
        android:textColor="@color/textPrimary"/>

    <!-- আয়-ব্যয় যোগ -->
    <LinearLayout android:id="@+id/menuAddIncomeExpense" style="@style/AddMenuRowStyle">
        <ImageView style="@style/AddMenuIconStyle" android:src="@drawable/ic_nav_income_expense"
            android:backgroundTint="@color/incomeColor"/>
        <TextView style="@style/AddMenuLabelStyle" android:text="@string/add_menu_income_expense"/>
    </LinearLayout>

    <!-- দেনা-পাওনা যোগ -->
    <LinearLayout android:id="@+id/menuAddDenaPawna" style="@style/AddMenuRowStyle">
        <ImageView style="@style/AddMenuIconStyle" android:src="@drawable/ic_nav_dena_pawna"
            android:backgroundTint="@color/ledgerColor"/>
        <TextView style="@style/AddMenuLabelStyle" android:text="@string/add_menu_dena_pawna"/>
    </LinearLayout>

    <!-- সঞ্চয় যোগ -->
    <LinearLayout android:id="@+id/menuAddSavings" style="@style/AddMenuRowStyle">
        <ImageView style="@style/AddMenuIconStyle" android:src="@drawable/ic_nav_savings"
            android:backgroundTint="@color/savingsColor"/>
        <TextView style="@style/AddMenuLabelStyle" android:text="@string/add_menu_savings"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/dividerColor"
        android:layout_marginVertical="6dp" android:layout_marginHorizontal="20dp"/>

    <!-- সেটিং -->
    <LinearLayout android:id="@+id/menuAddSettings" style="@style/AddMenuRowStyle">
        <ImageView style="@style/AddMenuIconStyle" android:src="@drawable/ic_nav_settings"
            android:backgroundTint="@color/secondaryTextDark"/>
        <TextView style="@style/AddMenuLabelStyle" android:text="@string/add_menu_settings"/>
    </LinearLayout>

</LinearLayout>
