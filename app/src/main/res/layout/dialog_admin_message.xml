<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_card"
    android:paddingBottom="22dp">

    <ImageView
        android:id="@+id/ivAdminMsgImage"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:scaleType="centerCrop"
        android:visibility="gone"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="26dp"
        android:paddingTop="24dp">

        <TextView
            android:id="@+id/tvAdminMsgTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvAdminMsgBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#C7D2FE"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnAdminMsgOk"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="ঠিক আছে"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:backgroundTint="#6366F1"/>
    </LinearLayout>
</LinearLayout>
