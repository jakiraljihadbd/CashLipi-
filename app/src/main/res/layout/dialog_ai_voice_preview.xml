<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:overScrollMode="never">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingTop="10dp"
    android:paddingBottom="24dp"
    android:paddingHorizontal="20dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_marginBottom="14dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_drag_handle"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨"
            android:textSize="20sp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="AI প্রিভিউ — যাচাই করে সংরক্ষণ করুন"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/textPrimary"/>
    </LinearLayout>

    <!-- Recognized raw speech text -->
    <TextView
        android:id="@+id/tvAiRawText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:textSize="12.5sp"
        android:textStyle="italic"
        android:textColor="@color/txnTabInactiveText"
        android:text="আপনি বলেছেন: ..."/>

    <!-- Income/Expense toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_txn_tab_container"
        android:orientation="horizontal"
        android:padding="4dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/aiTabIncome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="আয়"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_txn_tab_selected_income"
            android:textColor="@color/white"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/aiTabExpense"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="ব্যয়"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/txnTabInactiveText"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/aiTilAmount"
        style="@style/AppTextInputSmooth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="পরিমাণ"
        android:layout_marginBottom="12dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/aiEtAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="12dp"
            android:inputType="numberDecimal"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/textPrimary"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/aiTilCategory"
        style="@style/AppTextInputSmooth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="ক্যাটাগরি"
        android:layout_marginBottom="12dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/aiEtCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="12dp"
            android:inputType="textCapSentences"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="পেমেন্টের ধরণ"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/textPrimary"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:id="@+id/aiRowPaymentMethods"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"/>
    </HorizontalScrollView>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/aiTilNote"
        style="@style/AppTextInputSmooth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="নোট (ঐচ্ছিক)"
        android:layout_marginBottom="18dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/aiEtNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapSentences"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnAiCancel"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:text="বাতিল"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_txn_payment_item"
            android:textColor="@color/textPrimary"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btnAiSave"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1.4"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:text="✓ যাচাই করে সংরক্ষণ"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_txn_tab_selected_income"
            android:textColor="@color/white"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

</LinearLayout>
</androidx.core.widget.NestedScrollView>
