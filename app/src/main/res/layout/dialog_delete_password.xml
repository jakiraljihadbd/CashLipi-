<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/cardBg"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="28dp"
    android:paddingBottom="12dp"
    android:gravity="center_horizontal">

    <!-- আইকন -->
    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_danger_icon_circle">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_dialog_warning"
            app:tint="@color/bkDanger"
            android:contentDescription="@null"/>
    </FrameLayout>

    <!-- টাইটেল -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="পাসওয়ার্ড দিয়ে নিশ্চিত করুন"
        android:textColor="@color/textPrimary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"/>

    <!-- নির্দেশনা -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="আপনার অ্যাপের সম্পূর্ণ ডেটা মুছতে (0000) পাসওয়ার্ডটি ব্যবহার করুন"
        android:textColor="@color/textSecondary"
        android:textSize="14sp"
        android:lineSpacingExtra="3dp"
        android:gravity="center"/>

    <!-- ৪ ডিজিট পাসওয়ার্ড বক্স -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/etPinDigit1"
            android:layout_width="52dp"
            android:layout_height="56dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_pin_box"
            android:gravity="center"
            android:inputType="numberPassword"
            android:maxLength="1"
            android:cursorVisible="true"
            android:textColor="@color/textPrimary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:importantForAutofill="no"/>

        <EditText
            android:id="@+id/etPinDigit2"
            android:layout_width="52dp"
            android:layout_height="56dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_pin_box"
            android:gravity="center"
            android:inputType="numberPassword"
            android:maxLength="1"
            android:cursorVisible="true"
            android:textColor="@color/textPrimary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:importantForAutofill="no"/>

        <EditText
            android:id="@+id/etPinDigit3"
            android:layout_width="52dp"
            android:layout_height="56dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_pin_box"
            android:gravity="center"
            android:inputType="numberPassword"
            android:maxLength="1"
            android:cursorVisible="true"
            android:textColor="@color/textPrimary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:importantForAutofill="no"/>

        <EditText
            android:id="@+id/etPinDigit4"
            android:layout_width="52dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_pin_box"
            android:gravity="center"
            android:inputType="numberPassword"
            android:maxLength="1"
            android:cursorVisible="true"
            android:textColor="@color/textPrimary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:importantForAutofill="no"/>

    </LinearLayout>

    <!-- এরর মেসেজ (ভুল পাসওয়ার্ড দিলে দেখাবে) -->
    <TextView
        android:id="@+id/tvPinError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="❌ ভুল পাসওয়ার্ড, আবার চেষ্টা করুন"
        android:textColor="@color/bkDanger"
        android:textSize="13sp"
        android:textStyle="bold"
        android:visibility="gone"/>

</LinearLayout>
