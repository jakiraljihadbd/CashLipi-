<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvSettleQuestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15.5sp"
        android:textStyle="bold"
        android:textColor="@color/textPrimary"
        android:layout_marginBottom="12dp"/>

    <RadioGroup
        android:id="@+id/rgSettleOptions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/rbSettleBalance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13.5sp"
            android:textColor="@color/textPrimary"
            android:paddingVertical="6dp"
            android:checked="true"/>

        <RadioButton
            android:id="@+id/rbSettleSavings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13.5sp"
            android:textColor="@color/textPrimary"
            android:paddingVertical="6dp"/>

        <RadioButton
            android:id="@+id/rbSettleIncomeExpense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13.5sp"
            android:textColor="@color/textPrimary"
            android:paddingVertical="6dp"/>

        <RadioButton
            android:id="@+id/rbSettleNone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13.5sp"
            android:textColor="@color/textPrimary"
            android:paddingVertical="6dp"/>
    </RadioGroup>

    <!-- লাইভ প্রিভিউ — বর্তমান হিসাব বনাম এই লেনদেন যোগ হলে কী হবে -->
    <LinearLayout
        android:id="@+id/settlePreviewCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_card_white"
        android:padding="12dp"
        android:layout_marginTop="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="বর্তমান"
                android:textSize="10.5sp"
                android:textColor="@color/textSecondary"/>
            <TextView
                android:id="@+id/tvSettleBefore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13.5sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"/>
        </LinearLayout>

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_arrow_back"
            android:rotation="180"
            app:tint="@color/textSecondary"
            android:layout_marginHorizontal="8dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="এই লেনদেনের পর"
                android:textSize="10.5sp"
                android:textColor="@color/textSecondary"/>
            <TextView
                android:id="@+id/tvSettleAfter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13.5sp"
                android:textStyle="bold"
                android:textColor="@color/ledgerColor"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
