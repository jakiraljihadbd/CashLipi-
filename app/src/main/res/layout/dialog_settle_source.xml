<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <!-- হেডার — আইকন + বড়, বোল্ড প্রশ্ন -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="18dp">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="12dp">
                <ImageView
                    android:id="@+id/ivSettleIcon"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:padding="10dp"
                    android:background="@drawable/bg_icon_circle_receivable"
                    android:src="@drawable/ic_check_circle"
                    app:tint="@color/white"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tvSettleQuestion"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="17sp"
                android:textStyle="bold"
                android:lineSpacingExtra="2dp"
                android:textColor="@color/textPrimary"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="টাকাটা কোথায় হিসাব হবে বেছে নিন"
            android:textSize="12.5sp"
            android:textColor="@color/textSecondary"
            android:layout_marginBottom="10dp"/>

        <RadioGroup
            android:id="@+id/rgSettleOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rbSettleBalance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="54dp"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:paddingVertical="14dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_settle_option"
                android:buttonTint="@color/bkashPink"
                android:layout_marginBottom="10dp"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/rbSettleSavings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="54dp"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:paddingVertical="14dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_settle_option"
                android:buttonTint="@color/bkashPink"
                android:layout_marginBottom="10dp"/>

            <RadioButton
                android:id="@+id/rbSettleIncomeExpense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="54dp"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:paddingVertical="14dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_settle_option"
                android:buttonTint="@color/bkashPink"
                android:layout_marginBottom="10dp"/>

            <RadioButton
                android:id="@+id/rbSettleNone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="54dp"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:paddingVertical="14dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_settle_option"
                android:buttonTint="@color/bkashPink"/>
        </RadioGroup>

        <!-- লাইভ প্রিভিউ — বর্তমান হিসাব বনাম এই লেনদেন যোগ হলে কী হবে -->
        <LinearLayout
            android:id="@+id/settlePreviewCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card_white"
            android:padding="16dp"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="বর্তমান"
                    android:textSize="11sp"
                    android:textColor="@color/textSecondary"/>
                <TextView
                    android:id="@+id/tvSettleBefore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15.5sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"/>
            </LinearLayout>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_arrow_back"
                android:rotation="180"
                app:tint="@color/bkashPink"
                android:layout_marginHorizontal="10dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="এই লেনদেনের পর"
                    android:textSize="11sp"
                    android:textColor="@color/textSecondary"/>
                <TextView
                    android:id="@+id/tvSettleAfter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15.5sp"
                    android:textStyle="bold"
                    android:textColor="@color/ledgerColor"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
