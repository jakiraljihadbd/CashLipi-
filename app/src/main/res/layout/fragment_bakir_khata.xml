<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgColor">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- আরও চিকন হেডার — অ্যাপ বার কালারে, একই লাইনে ব্যক্তি সংখ্যা + মোট লেনদেন (ছোট করে) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/m3HomeBalanceContainer"
            android:paddingHorizontal="18dp">

            <TextView
                android:id="@+id/tvHeaderTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ব্যক্তি ও প্রতিষ্ঠান"
                android:textSize="12.5sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvKhataCustomerCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="মোট লেনদেন নেই"
                android:textSize="10.5sp"
                android:textColor="#D9FFFFFF"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- বিজনেস ওয়ালেট চিপ + দ্রুত অ্যাকশন (খরচ/জমা) — মূল একাউন্ট থেকে সম্পূর্ণ আলাদা পকেট -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/cardBackground"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp">

            <LinearLayout
                android:id="@+id/chipKhataWallet"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_dialog_field"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ওয়ালেট"
                    android:textSize="11.5sp"
                    android:textColor="@color/textSecondary"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tvKhataWalletBalance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="৳০"
                    android:textSize="13.5sp"
                    android:textStyle="bold"
                    android:textColor="@color/khataWalletColor"
                    android:maxLines="1"
                    android:ellipsize="end"/>
            </LinearLayout>

            <TextView
                android:id="@+id/btnKhataAddExpense"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="9dp"
                android:text="+ খরচ"
                android:textSize="12.5sp"
                android:textStyle="bold"
                android:textColor="@color/bakiColor"
                android:background="@drawable/bg_dialog_field"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btnKhataAddJoma"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="9dp"
                android:text="+ জমা"
                android:textSize="12.5sp"
                android:textStyle="bold"
                android:textColor="@color/jomaColor"
                android:background="@drawable/bg_dialog_field"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="8dp"/>

        <!-- অটো-স্লাইড ব্যানার — কার বাকি এখনও আদায় হয়নি, সেটা একটাই কার্ডে (বাকি হলে লাল,
             অগ্রিম হলে সবুজ ব্যাকগ্রাউন্ড) দেখায় এবং ৫ সেকেন্ড পরপর পরের গ্রাহকে বদলায়।

             আগে এখানে একটা খালি FrameLayout (bannerCardHolder) ছিল, যার ভেতরে কোডে
             ডাইনামিকভাবে item_debt_banner_khata/khata_joma ইনফ্লেট করে addView/removeView
             করা হতো — কিছু ডিভাইসে সেই মুহূর্তে কার্ডটা খালি/সাদা দেখা যাচ্ছিল (দেনা-পাওনা
             পেজেও একই বাগ ছিল, ওখানে ঠিক করার সময় এখানেও একইভাবে ঠিক করা হলো)। এখন
             কার্ডটা সরাসরি স্ট্যাটিকভাবে লেখা — bannerCardRoot সবসময় বিদ্যমান এবং সবসময় একটা
             background নিয়েই তৈরি হয়, কোডে শুধু setBackgroundResource() ও টেক্সট বদলানো
             হয়, কখনও কোনো ভিউ যোগ/বাদ দেওয়া হয় না। -->
        <FrameLayout
            android:id="@+id/bannerContainer"
            android:layout_width="match_parent"
            android:layout_height="78dp"
            android:layout_marginHorizontal="18dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/bannerCardRoot"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="18dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_debt_banner_khata"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_banner_avatar_plain"
                    android:gravity="center"
                    android:layout_marginEnd="12dp">

                    <TextView
                        android:id="@+id/tvBannerInitial"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="?"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvBannerName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="15.5sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:maxLines="1"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/tvBannerSub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textSize="12sp"
                        android:textColor="@color/white"
                        android:alpha="0.9"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/tvBannerAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"/>

                    <TextView
                        android:id="@+id/tvBannerLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:textSize="11sp"
                        android:textColor="@color/white"
                        android:alpha="0.9"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/debtDots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal"
                android:gravity="center"/>
        </FrameLayout>

        <!-- Search + ফিল্টার + থিম চেঞ্জ — এক লাইনে, প্রোফেশনাল লেভেল -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="18dp"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_search_premium"
                android:paddingStart="14dp"
                android:paddingEnd="10dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_search"
                    android:layout_marginEnd="10dp"
                    android:alpha="0.7"/>

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:inputType="text"
                    android:hint="নাম বা ফোন নম্বর খুঁজুন..."
                    android:textSize="14sp"
                    android:textColor="@color/searchTextColor"
                    android:textColorHint="@color/searchHintColor"
                    android:background="@android:color/transparent"
                    android:singleLine="true"
                    android:maxLines="1"
                    android:imeOptions="actionSearch"
                    android:cursorVisible="true"/>

                <ImageView
                    android:id="@+id/ivClearSearch"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_clear"
                    android:layout_marginStart="6dp"
                    android:visibility="gone"
                    android:alpha="0.6"
                    android:padding="2dp"/>
            </LinearLayout>

            <!-- ফিল্টার আইকন — সব / অপরিশোধিত / পরিশোধিত (পপআপ মেনু) -->
            <FrameLayout
                android:id="@+id/btnFilter"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_icon_action_btn"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="19dp"
                    android:layout_height="19dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_filter"
                    app:tint="@color/colorPrimary"/>

                <View
                    android:id="@+id/filterActiveDot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="5dp"
                    android:background="@drawable/dot_filter_active"
                    android:visibility="gone"/>
            </FrameLayout>

            <!-- থিম চেঞ্জ আইকন — কার্ড ৪-৫ স্টাইলে দেখানোর অপশন -->
            <FrameLayout
                android:id="@+id/btnThemeChange"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_icon_action_btn"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="19dp"
                    android:layout_height="19dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_theme_palette"
                    app:tint="@color/colorPrimary"/>
            </FrameLayout>
        </LinearLayout>

        <!-- তালিকা -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvKhataCustomerList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="14dp"
            android:paddingBottom="90dp"
            android:clipToPadding="false"
            android:overScrollMode="never"/>

        <!-- খালি অবস্থা (কোনো ব্যক্তিই নেই) -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:paddingBottom="60dp">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_empty_people"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="কোনো ব্যক্তি বা প্রতিষ্ঠান যোগ নেই"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="নিচের + বাটনে চেপে নতুন ব্যক্তি যোগ করুন"
                android:textSize="13sp"
                android:textColor="@color/textSecondary"/>
        </LinearLayout>

        <!-- খালি অবস্থা (ফিল্টার/সার্চে কিছু মেলেনি) -->
        <LinearLayout
            android:id="@+id/noResultState"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:paddingBottom="60dp">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_search"
                android:alpha="0.35"
                android:layout_marginBottom="14dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="কোনো ফলাফল পাওয়া যায়নি"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="অন্য নাম দিয়ে খুঁজুন বা ফিল্টার বদলান"
                android:textSize="13sp"
                android:textColor="@color/textSecondary"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ফ্লোটিং + বাটন -->
    <LinearLayout
        android:id="@+id/btnAddKhataCustomer"
        android:layout_width="62dp"
        android:layout_height="62dp"
        android:background="@drawable/bg_fab_bakir_khata"
        android:gravity="center"
        android:elevation="10dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="22dp"
        android:layout_marginEnd="18dp">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_add_plain"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
