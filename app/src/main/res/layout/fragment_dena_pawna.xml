<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgColor">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- হেডার -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingTop="18dp"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="দেনা পাওনা"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"/>

            <TextView
                android:id="@+id/tvPersonCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="যাদের সাথে হিসাব রাখবেন, তাদের যোগ করুন"
                android:textSize="13sp"
                android:textColor="@color/textSecondary"/>
        </LinearLayout>

        <!-- অটো-স্লাইড ব্যানার — কার টাকা এখনও পরিশোধ হয়নি, রঙিনভাবে পালা করে দেখায় -->
        <FrameLayout
            android:id="@+id/bannerContainer"
            android:layout_width="match_parent"
            android:layout_height="78dp"
            android:layout_marginHorizontal="18dp"
            android:layout_marginBottom="14dp"
            android:visibility="gone">

            <ViewFlipper
                android:id="@+id/debtFlipper"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:flipInterval="3000"
                android:inAnimation="@anim/slide_in_right"
                android:outAnimation="@anim/slide_out_left"/>

            <LinearLayout
                android:id="@+id/debtDots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal"
                android:gravity="center"/>
        </FrameLayout>

        <!-- Search -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="18dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_search_premium"
            android:paddingStart="14dp"
            android:paddingEnd="10dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                android:layout_marginEnd="10dp"
                android:alpha="0.7"/>

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="text"
                android:hint="নাম বা ফোন নম্বর খুঁজুন..."
                android:textSize="14sp"
                android:textColor="@color/searchTextColor"
                android:textColorHint="@color/searchHintColor"
                android:background="@android:color/transparent"
                android:singleLine="true"
                android:maxLines="1"
                android:imeOptions="actionSearch"
                android:cursorVisible="true"/>

            <ImageView
                android:id="@+id/ivClearSearch"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_clear"
                android:layout_marginStart="6dp"
                android:visibility="gone"
                android:alpha="0.6"
                android:padding="2dp"/>
        </LinearLayout>

        <!-- ফিল্টার চিপ — সব / অপরিশোধিত / পরিশোধিত -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="18dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/chipAll"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="সব"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_chip_selected"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:layout_marginEnd="7dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/chipUnpaid"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="অপরিশোধিত"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:textColor="@color/chipUnselectedText"
                    android:textStyle="bold"
                    android:layout_marginEnd="7dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/chipPaid"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="পরিশোধিত"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:textColor="@color/chipUnselectedText"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- তালিকা -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPersonList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="14dp"
            android:paddingBottom="90dp"
            android:clipToPadding="false"
            android:overScrollMode="never"/>

        <!-- খালি অবস্থা (কোনো ব্যক্তিই নেই) -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:paddingBottom="60dp">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_empty_people"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="কোনো ব্যক্তি বা প্রতিষ্ঠান যোগ নেই"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="নিচের + বাটনে চেপে নতুন ব্যক্তি যোগ করুন"
                android:textSize="13sp"
                android:textColor="@color/textSecondary"/>
        </LinearLayout>

        <!-- খালি অবস্থা (ফিল্টার/সার্চে কিছু মেলেনি) -->
        <LinearLayout
            android:id="@+id/noResultState"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:paddingBottom="60dp">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_search"
                android:alpha="0.35"
                android:layout_marginBottom="14dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="কোনো ফলাফল পাওয়া যায়নি"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="অন্য নাম দিয়ে খুঁজুন বা ফিল্টার বদলান"
                android:textSize="13sp"
                android:textColor="@color/textSecondary"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ফ্লোটিং + বাটন -->
    <LinearLayout
        android:id="@+id/btnAddPerson"
        android:layout_width="62dp"
        android:layout_height="62dp"
        android:background="@drawable/bg_fab_dena_pawna"
        android:gravity="center"
        android:elevation="10dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="22dp"
        android:layout_marginEnd="18dp">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_add_plain"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
