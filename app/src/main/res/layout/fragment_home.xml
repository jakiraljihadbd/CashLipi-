<?xml version="1.0" encoding="utf-8"?>
<!--
  HomeFragment — নতুন ডিজাইন (আগের ডিজাইন সম্পূর্ণ পরিবর্তিত):
  1) উপরে অটো-স্লাইডিং AI পরামর্শ কার্ড (৪ সেকেন্ড পরপর পরিবর্তন হয়, নিচে ডট ইন্ডিকেটর)
  2) পিংক ব্যালেন্স কার্ড
  3) আয় + ব্যয়
  4) দেনা + পাওনা
  5) চিকন সঞ্চয় বার
  6) কুইক মেনু গ্রিড — AI Chat, এনালাইসিস, বাকির খাতা, ক্যালকুলেটর, নোট, একাউন্টিং
-->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgColor"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="24dp">

        <!-- ══════════════════════════════
             AUTO-SLIDING AI TIP CAROUSEL
        ══════════════════════════════ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <ViewFlipper
                android:id="@+id/tipFlipper"
                android:layout_width="match_parent"
                android:layout_height="94dp"
                android:flipInterval="4000"
                android:inAnimation="@android:anim/fade_in"
                android:outAnimation="@android:anim/fade_out"
                android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <!-- child cards are added dynamically in HomeFragment.java based on real data -->
            </ViewFlipper>

            <!-- dot indicators, overlaid bottom-center -->
            <LinearLayout
                android:id="@+id/tipDots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="10dp"
                android:orientation="horizontal"
                android:gravity="center"/>
        </FrameLayout>

        <!-- ══════════════════════════════
             BALANCE CARD (PINK)
        ══════════════════════════════ -->
        <FrameLayout
            android:id="@+id/balanceCard"
            android:layout_width="match_parent"
            android:layout_height="172dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_balance_pink"
            android:clickable="true" android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:elevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- top row: label pill + status -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_balance_pill"
                        android:paddingHorizontal="10dp">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_eye"
                            app:tint="#FFFFFF"
                            android:layout_marginEnd="6dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="এই মাস"
                            android:textSize="11sp" android:textStyle="bold"
                            android:textColor="#FFFFFF"/>
                    </LinearLayout>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"/>

                    <TextView
                        android:id="@+id/balanceStatusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="সচল"
                        android:textSize="11sp" android:textStyle="bold"
                        android:textColor="#DFFFFFFF"/>
                </LinearLayout>

                <View
                    android:layout_width="0dp" android:layout_height="0dp"
                    android:layout_weight="1"/>

                <!-- ব্যালেন্স label + amount -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ব্যালেন্স"
                    android:textSize="13sp" android:textStyle="bold"
                    android:textColor="#DFFFFFFF"
                    android:letterSpacing="0.03"
                    android:layout_marginBottom="2dp"/>

                <TextView
                    android:id="@+id/tvMainBalance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="৳ 0"
                    android:textSize="38sp" android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <View
                    android:layout_width="0dp" android:layout_height="0dp"
                    android:layout_weight="1"/>

                <!-- বিস্তারিত দেখুন pill -->
                <LinearLayout
                    android:id="@+id/balanceCardClick"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_balance_detail_pill"
                    android:paddingHorizontal="16dp"
                    android:clickable="true" android:focusable="true">
                    <ImageView
                        android:layout_width="13dp"
                        android:layout_height="13dp"
                        android:src="@drawable/emoji_bar_chart"
                        android:layout_marginEnd="6dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="বিস্তারিত দেখুন"
                        android:textSize="11sp" android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- ══════════════════════════════
             আয় + ব্যয়
        ══════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <FrameLayout
                android:id="@+id/cardIncome"
                android:layout_width="0dp"
                android:layout_height="96dp"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:background="@drawable/bg_summary_income"
                android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:elevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center" android:padding="10dp">
                    <ImageView
                        android:layout_width="26dp" android:layout_height="26dp"
                        android:src="@drawable/emoji_money_bag"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="আয়"
                        android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/m3OnIncomeContainer"
                        android:alpha="0.8"/>
                    <TextView
                        android:id="@+id/tvTotalIncome"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="৳ 0"
                        android:textSize="17sp" android:textStyle="bold"
                        android:textColor="@color/m3OnIncomeContainer"/>
                </LinearLayout>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/cardExpense"
                android:layout_width="0dp"
                android:layout_height="96dp"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:background="@drawable/bg_summary_expense"
                android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:elevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center" android:padding="10dp">
                    <ImageView
                        android:layout_width="26dp" android:layout_height="26dp"
                        android:src="@drawable/emoji_money_with_wings"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ব্যয়"
                        android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/m3OnExpenseContainer"
                        android:alpha="0.8"/>
                    <TextView
                        android:id="@+id/tvTotalExpense"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="৳ 0"
                        android:textSize="17sp" android:textStyle="bold"
                        android:textColor="@color/m3OnExpenseContainer"/>
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <!-- ══════════════════════════════
             দেনা + পাওনা  (লোন পেলাম/দিলাম-এর বদলে)
        ══════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <FrameLayout
                android:id="@+id/cardDena"
                android:layout_width="0dp"
                android:layout_height="88dp"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:background="@drawable/bg_summary_dena"
                android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:elevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center" android:padding="8dp">
                    <ImageView
                        android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@drawable/emoji_book_red"
                        android:layout_marginBottom="3dp"/>
                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="দেনা"
                        android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/m3OnDenaContainer"
                        android:alpha="0.8"/>
                    <TextView
                        android:id="@+id/tvTotalDena"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="৳ 0"
                        android:textSize="16sp" android:textStyle="bold"
                        android:textColor="@color/m3OnDenaContainer"/>
                </LinearLayout>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/cardPabona"
                android:layout_width="0dp"
                android:layout_height="88dp"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:background="@drawable/bg_summary_pabona"
                android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:elevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center" android:padding="8dp">
                    <ImageView
                        android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@drawable/emoji_book_green"
                        android:layout_marginBottom="3dp"/>
                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="পাওনা"
                        android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/m3OnPabonaContainer"
                        android:alpha="0.8"/>
                    <TextView
                        android:id="@+id/tvTotalPabona"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="৳ 0"
                        android:textSize="16sp" android:textStyle="bold"
                        android:textColor="@color/m3OnPabonaContainer"/>
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <!-- ══════════════════════════════
             সঞ্চয় (চিকন ফুল-উইডথ বার)
        ══════════════════════════════ -->
        <FrameLayout
            android:id="@+id/cardSavings"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_summary_savings"
            android:clickable="true" android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:elevation="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/emoji_green_heart"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="সঞ্চয়"
                    android:textSize="12sp" android:textStyle="bold"
                    android:textColor="@color/m3OnSavingsContainer"
                    android:alpha="0.8"
                    android:letterSpacing="0.04"/>

                <TextView
                    android:id="@+id/tvTotalSavings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="৳ 0"
                    android:textSize="20sp" android:textStyle="bold"
                    android:textColor="@color/m3OnSavingsContainer"/>
            </LinearLayout>
        </FrameLayout>

        <!-- ══════════════════════════════
             কুইক মেনু গ্রিড
        ══════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="কুইক মেনু"
            android:textSize="13sp" android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:layout_marginBottom="8dp"
            android:letterSpacing="0.02"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <!-- 1. AI Chat -->
            <LinearLayout
                android:id="@+id/menuAiChat"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical" android:gravity="center"
                android:background="@drawable/bg_menu_item_card"
                android:paddingVertical="14dp"
                android:layout_marginEnd="6dp"
                android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:elevation="0dp">
                <FrameLayout
                    android:layout_width="46dp" android:layout_height="46dp"
                    android:background="@drawable/bg_menu_icon_circle"
                    android:backgroundTint="#EEF2FF"
                    android:layout_marginBottom="6dp">
                    <ImageView
                        android:layout_width="24dp" android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/emoji_robot"/>
                </FrameLayout>
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="AI Chat"
                    android:textSize="10.5sp" android:textStyle="bold"
                    android:textColor="@color/textPrimary"/>
            </LinearLayout>

            <!-- 2. এনালাইসিস -->
            <LinearLayout
                android:id="@+id/menuAnalysis"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical" android:gravity="center"
                android:background="@drawable/bg_menu_item_card"
                android:paddingVertical="14dp"
                android:layout_marginEnd="6dp"
                android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:elevation="0dp">
                <FrameLayout
                    android:layout_width="46dp" android:layout_height="46dp"
                    android:background="@drawable/bg_menu_icon_circle"
                    android:backgroundTint="#EFF6FF"
                    android:layout_marginBottom="6dp">
                    <ImageView
                        android:layout_width="24dp" android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/emoji_chart_up"/>
                </FrameLayout>
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="এনালাইসিস"
                    android:textSize="10.5sp" android:textStyle="bold"
                    android:textColor="@color/textPrimary"/>
            </LinearLayout>

            <!-- 3. বাকির খাতা -->
            <LinearLayout
                android:id="@+id/menuLedger"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical" android:gravity="center"
                android:background="@drawable/bg_menu_item_card"
                android:paddingVertical="14dp"
                android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:elevation="0dp">
                <FrameLayout
                    android:layout_width="46dp" android:layout_height="46dp"
                    android:background="@drawable/bg_menu_icon_circle"
                    android:backgroundTint="#FFFBEB"
                    android:layout_marginBottom="6dp">
                    <ImageView
                        android:layout_width="24dp" android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/emoji_ledger"/>
                </FrameLayout>
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="বাকির খাতা"
                    android:textSize="10.5sp" android:textStyle="bold"
                    android:textColor="@color/textPrimary"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- 4. ক্যালকুলেটর -->
            <LinearLayout
                android:id="@+id/menuCalculator"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical" android:gravity="center"
                android:background="@drawable/bg_menu_item_card"
                android:paddingVertical="14dp"
                android:layout_marginEnd="6dp"
                android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:elevation="0dp">
                <FrameLayout
                    android:layout_width="46dp" android:layout_height="46dp"
                    android:background="@drawable/bg_menu_icon_circle"
                    android:backgroundTint="#F0FDFA"
                    android:layout_marginBottom="6dp">
                    <ImageView
                        android:layout_width="24dp" android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/emoji_abacus"/>
                </FrameLayout>
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ক্যালকুলেটর"
                    android:textSize="10.5sp" android:textStyle="bold"
                    android:textColor="@color/textPrimary"/>
            </LinearLayout>

            <!-- 5. নোট -->
            <LinearLayout
                android:id="@+id/menuNotes"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical" android:gravity="center"
                android:background="@drawable/bg_menu_item_card"
                android:paddingVertical="14dp"
                android:layout_marginEnd="6dp"
                android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:elevation="0dp">
                <FrameLayout
                    android:layout_width="46dp" android:layout_height="46dp"
                    android:background="@drawable/bg_menu_icon_circle"
                    android:backgroundTint="#FDF2F8"
                    android:layout_marginBottom="6dp">
                    <ImageView
                        android:layout_width="24dp" android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/emoji_memo"/>
                </FrameLayout>
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="নোট"
                    android:textSize="10.5sp" android:textStyle="bold"
                    android:textColor="@color/textPrimary"/>
            </LinearLayout>

            <!-- 6. একাউন্টিং -->
            <LinearLayout
                android:id="@+id/menuAccounting"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical" android:gravity="center"
                android:background="@drawable/bg_menu_item_card"
                android:paddingVertical="14dp"
                android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:elevation="0dp">
                <FrameLayout
                    android:layout_width="46dp" android:layout_height="46dp"
                    android:background="@drawable/bg_menu_icon_circle"
                    android:backgroundTint="#ECFDF5"
                    android:layout_marginBottom="6dp">
                    <ImageView
                        android:layout_width="24dp" android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/emoji_bank"/>
                </FrameLayout>
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="একাউন্টিং"
                    android:textSize="10.5sp" android:textStyle="bold"
                    android:textColor="@color/textPrimary"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
