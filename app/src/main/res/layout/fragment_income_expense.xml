<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ieGreyBg">

    <LinearLayout
        android:id="@+id/contentColumn"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- ===== আয় / ব্যয় টগল — বড়, ফুল-ওয়েট, কালারফুল ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:background="@drawable/ie_view_tab_track"
            android:padding="4dp"
            android:elevation="4dp">

            <TextView
                android:id="@+id/tabIncome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="আয়"
                android:textSize="17sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tabExpense"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:gravity="center"
                android:text="ব্যয়"
                android:textSize="17sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- ===== মাসিক সারসংক্ষেপ — কমপ্যাক্ট, কালারফুল (টগলের পরেই) ===== -->
        <LinearLayout
            android:id="@+id/monthSummaryCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="7dp"
            android:background="@drawable/ie_summary_bg_income">

            <ImageView
                android:id="@+id/ivMonthIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="7dp"
                android:src="@drawable/ic_plus_circle"
                android:scaleType="centerInside"
                android:background="@drawable/ie_summary_icon_income"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/tvMonthTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="এই মাসের মোট আয়"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/ieIncomeText"
                    android:alpha="0.85"/>

                <TextView
                    android:id="@+id/tvMonthAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="৳ 0"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="@color/ieIncomeText"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ===== সার্চ + PDF + প্রিন্ট + সর্ট (স্কয়ার, কালারফুল, উঁচু elevation) ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/ie_search_bg"
                android:elevation="3dp"
                android:paddingStart="14dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:layout_width="19dp"
                    android:layout_height="19dp"
                    android:src="@drawable/ic_search"
                    android:layout_marginEnd="8dp"
                    android:alpha="0.6"/>

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:inputType="text"
                    android:hint="অনুসন্ধান করুন..."
                    android:textSize="13.5sp"
                    android:textStyle="bold"
                    android:textColor="@color/ieDarkText"
                    android:textColorHint="#9AA0A6"
                    android:background="@android:color/transparent"
                    android:singleLine="true"
                    android:maxLines="1"
                    android:imeOptions="actionSearch"/>

                <ImageView
                    android:id="@+id/ivClearSearch"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_clear"
                    android:layout_marginStart="4dp"
                    android:visibility="gone"
                    android:alpha="0.6"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/btnPdf"
                android:layout_width="46dp"
                android:layout_height="48dp"
                android:layout_marginStart="6dp"
                android:padding="11dp"
                android:src="@drawable/ic_pdf"
                android:scaleType="centerInside"
                app:tint="@color/ieWhite"
                android:background="@drawable/ie_icon_btn_income"
                android:elevation="3dp"
                android:clickable="true"
                android:focusable="true"/>

            <ImageView
                android:id="@+id/btnPrint"
                android:layout_width="46dp"
                android:layout_height="48dp"
                android:layout_marginStart="6dp"
                android:padding="11dp"
                android:src="@drawable/ic_print"
                android:scaleType="centerInside"
                app:tint="@color/ieWhite"
                android:background="@drawable/ie_icon_btn_income"
                android:elevation="3dp"
                android:clickable="true"
                android:focusable="true"/>

            <ImageView
                android:id="@+id/btnSort"
                android:layout_width="46dp"
                android:layout_height="48dp"
                android:layout_marginStart="6dp"
                android:padding="11dp"
                android:src="@drawable/ic_sort"
                android:scaleType="centerInside"
                app:tint="@color/ieWhite"
                android:background="@drawable/ie_icon_btn_income"
                android:elevation="3dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- ===== ভিউ সুইচার: কার্ড / ছক / বিশ্লেষণ (স্কয়ার, কালারফুল) ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:background="@drawable/ie_view_tab_track"
            android:padding="3dp">

            <TextView
                android:id="@+id/btnViewCard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="কার্ড ভিউ"
                android:gravity="center"
                android:textSize="12.5sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btnViewTable"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:text="ছক ভিউ"
                android:gravity="center"
                android:textSize="12.5sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btnViewAnalysis"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:text="বিশ্লেষণ"
                android:gravity="center"
                android:textSize="12.5sp"
                android:textStyle="bold"
                android:textColor="@color/ieDarkText"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Filter Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="6dp">
            <LinearLayout
                android:id="@+id/chipRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"/>
        </HorizontalScrollView>

        <!-- Card view -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="12dp"
            android:paddingTop="2dp"
            android:paddingBottom="80dp"
            android:clipToPadding="false"
            android:overScrollMode="never"/>

        <!-- Table (ছক) view — মাসিক ভিত্তিক, শুধু দেখার জন্য (এডিট করা যাবে না) -->
        <ScrollView
            android:id="@+id/tableContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone"
            android:overScrollMode="never"
            android:paddingHorizontal="12dp"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/tableMonthsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="80dp"/>
        </ScrollView>

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/emoji_empty_mailbox"
                android:scaleType="centerInside"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="কোনো তথ্য নেই"
                android:textSize="16sp"
                android:textColor="@color/ieDarkText"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="নিচের বাটন থেকে যোগ করুন"
                android:textSize="13sp"
                android:textColor="@color/ieDarkText"
                android:alpha="0.6"
                android:layout_marginTop="6dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ===== ফ্লোটিং অ্যাড বাটন — স্কয়ার-রাউন্ড, কালারফুল ===== -->
    <LinearLayout
        android:id="@+id/btnAddNew"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/ie_fab_income"
        android:gravity="center"
        android:elevation="10dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="22dp"
        android:layout_marginEnd="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/ieWhite"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
