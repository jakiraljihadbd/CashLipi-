<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/appBg">

    <LinearLayout
        android:id="@+id/contentColumn"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- ===== আয় / ব্যয় টগল পিল ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_txn_tab_container"
            android:padding="4dp"
            android:elevation="3dp">

            <TextView
                android:id="@+id/tabIncome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text=" আয়"
                android:textSize="15sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tabExpense"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:gravity="center"
                android:text=" ব্যয়"
                android:textSize="15sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- ===== সার্চ + PDF + প্রিন্ট ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_search_premium"
                android:paddingStart="14dp"
                android:paddingEnd="10dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_search"
                    android:layout_marginEnd="8dp"
                    android:alpha="0.7"/>

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:inputType="text"
                    android:hint="অনুসন্ধান করুন..."
                    android:textSize="13.5sp"
                    android:textColor="@color/searchTextColor"
                    android:textColorHint="@color/searchHintColor"
                    android:background="@android:color/transparent"
                    android:singleLine="true"
                    android:maxLines="1"
                    android:imeOptions="actionSearch"/>

                <ImageView
                    android:id="@+id/ivClearSearch"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_clear"
                    android:layout_marginStart="4dp"
                    android:visibility="gone"
                    android:alpha="0.6"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/btnPdf"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:padding="10dp"
                android:src="@drawable/ic_pdf"
                android:scaleType="centerInside"
                android:background="@drawable/bg_icon_btn_light"
                android:clickable="true"
                android:focusable="true"/>

            <ImageView
                android:id="@+id/btnPrint"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:padding="10dp"
                android:src="@drawable/ic_print"
                android:scaleType="centerInside"
                android:background="@drawable/bg_icon_btn_light"
                android:clickable="true"
                android:focusable="true"/>

            <ImageView
                android:id="@+id/btnSort"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:padding="10dp"
                android:src="@drawable/ic_sort"
                android:scaleType="centerInside"
                android:background="@drawable/bg_icon_btn_light"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- ===== ভিউ সুইচার: কার্ড ভিউ / ছক ভিউ / বিশ্লেষণ ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_view_toggle_track"
            android:padding="3dp">

            <TextView
                android:id="@+id/btnViewCard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text=" কার্ড ভিউ"
                android:gravity="center"
                android:textSize="12sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btnViewTable"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:text=" ছক ভিউ"
                android:gravity="center"
                android:textSize="12sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btnViewAnalysis"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:text=" বিশ্লেষণ"
                android:gravity="center"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/chipUnselectedText"
                android:background="@drawable/bg_icon_btn_light"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- ===== মাসিক সারসংক্ষেপ কার্ড ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/cardWhite">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvMonthTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="বর্তমান মাসের সারসংক্ষেপ (আয়)"
                    android:textSize="12.5sp"
                    android:textColor="@color/textSecondary"/>

                <TextView
                    android:id="@+id/tvMonthAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="+ ৳ 0"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:textColor="@color/amountIncome"/>

                <TextView
                    android:id="@+id/tvMonthSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="(সর্বশেষ হালনাগাদ: --)"
                    android:textSize="11.5sp"
                    android:textColor="@color/textHint"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Filter Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="8dp">
            <LinearLayout
                android:id="@+id/chipRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"/>
        </HorizontalScrollView>

        <!-- Card view -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="16dp"
            android:paddingTop="2dp"
            android:paddingBottom="80dp"
            android:clipToPadding="false"
            android:overScrollMode="never"/>

        <!-- Table (ছক) view -->
        <LinearLayout
            android:id="@+id/tableContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <include android:id="@+id/tableHeader" layout="@layout/item_transaction_table_header"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTable"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@drawable/bg_table_body"
                android:overScrollMode="never"/>
        </LinearLayout>

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/emoji_empty_mailbox"
                android:scaleType="centerInside"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="কোনো তথ্য নেই"
                android:textSize="16sp"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="নিচের বাটন থেকে যোগ করুন"
                android:textSize="13sp"
                android:textColor="@color/textSecondary"
                android:layout_marginTop="6dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ===== ফ্লোটিং অ্যাড বাটন ===== -->
    <LinearLayout
        android:id="@+id/btnAddNew"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_fab_income"
        android:gravity="center"
        android:elevation="8dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp"
        android:layout_marginEnd="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/white"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
