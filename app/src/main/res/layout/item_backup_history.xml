<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="@color/darkBgDeep"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Row 1: DateTime + Status -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <!-- Format badge -->
            <TextView android:id="@+id/tvHistoryFormat"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="JSON"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/badge_format_bg"
                android:layout_marginEnd="12dp"/>

            <!-- Date + Type -->
            <LinearLayout android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView android:id="@+id/tvHistoryDateTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <TextView android:id="@+id/tvHistoryDataType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/textSecondary"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Status badge -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardHistoryStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardBackgroundColor="@color/incomeBg"
                app:cardElevation="0dp">
                <TextView android:id="@+id/tvHistoryStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" সফল"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"/>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/white10"
            android:layout_marginBottom="10dp"/>

        <!-- Row 2: Method + Size -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView android:id="@+id/tvHistoryMethod"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/bottomNavUnselected"
                android:textSize="12sp"/>

            <TextView android:id="@+id/tvHistorySize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/textSecondary"
                android:textSize="11sp"
                android:background="@drawable/badge_dark_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
