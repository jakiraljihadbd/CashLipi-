<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="start"
    android:paddingVertical="4dp" android:paddingHorizontal="12dp">
    <ImageView
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/emoji_robot"
        android:scaleType="centerInside"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="4dp"/>
    <TextView android:id="@+id/tvMessage" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:maxWidth="260dp"
        android:background="@drawable/bg_ai_bot_msg" android:padding="12dp"
        android:textSize="14sp" android:textColor="@color/textPrimary"/>
</LinearLayout>
