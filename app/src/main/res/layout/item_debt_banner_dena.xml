<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bannerCardRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="18dp"
    android:clickable="true"
    android:focusable="true"
    android:background="@drawable/bg_debt_banner_dena"
    android:foreground="?attr/selectableItemBackground">

    <!-- initial বৃত্ত -->
    <LinearLayout
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:background="@drawable/bg_banner_avatar_plain"
        android:gravity="center"
        android:layout_marginEnd="12dp">

        <TextView
            android:id="@+id/tvBannerInitial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="?"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvBannerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15.5sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tvBannerSub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:alpha="0.9"
            android:maxLines="1"
            android:ellipsize="end"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/tvBannerAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"/>

        <TextView
            android:id="@+id/tvBannerLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:textSize="11sp"
            android:textColor="@color/white"
            android:alpha="0.9"/>
    </LinearLayout>

</LinearLayout>
