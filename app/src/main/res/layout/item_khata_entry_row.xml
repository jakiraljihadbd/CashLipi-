<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="14dp"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="9dp"
    android:gravity="center_vertical"
    android:background="@drawable/bg_card_premium_ripple"
    android:elevation="4dp"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/ivRowIcon"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:src="@drawable/emoji_book_red"
        android:scaleType="centerInside"
        android:padding="8dp"
        android:background="@drawable/bg_icon_circle_ledger"
        android:layout_marginEnd="12dp"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvRowType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14.5sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"/>

            <TextView
                android:id="@+id/tvRowPaidBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:background="@drawable/bg_paid_badge"
                android:paddingHorizontal="7dp"
                android:paddingVertical="2dp"
                android:text=" পরিশোধিত"
                android:textSize="9.5sp"
                android:textStyle="bold"
                android:textColor="@color/amountIncome"
                android:visibility="gone"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvRowNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="11.5sp"
            android:textColor="@color/textSecondary"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tvRowDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="11sp"
            android:textColor="@color/textSecondary"
            android:alpha="0.8"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        android:layout_marginStart="8dp">

        <TextView
            android:id="@+id/tvRowAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16.5sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvRowBalanceChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_ledger_balance_chip"
            android:paddingHorizontal="9dp"
            android:paddingVertical="2.5dp"
            android:textSize="10sp"
            android:textStyle="bold"/>
    </LinearLayout>

</LinearLayout>
