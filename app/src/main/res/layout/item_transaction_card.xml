<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginBottom="8dp"
    android:background="@drawable/ie_card_bg">

    <View
        android:id="@+id/viewColorBar"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="@color/ieIncomeDark"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- শিরোনাম + পরিমাণ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvItemTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/ieDarkText"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvItemAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="@color/ieIncomeText"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- তারিখ • সময় -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_calendar"
                android:alpha="0.55"/>

            <TextView
                android:id="@+id/tvItemDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12.5sp"
                android:textColor="@color/ieDarkText"
                android:alpha="0.72"
                android:layout_marginStart="5dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" • "
                android:textSize="12.5sp"
                android:textColor="@color/ieDarkText"
                android:alpha="0.5"/>

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_clock"
                android:alpha="0.55"/>

            <TextView
                android:id="@+id/tvItemTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12.5sp"
                android:textColor="@color/ieDarkText"
                android:alpha="0.72"
                android:layout_marginStart="5dp"/>
        </LinearLayout>

        <!-- নোট -->
        <LinearLayout
            android:id="@+id/rowNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_edit"
                android:alpha="0.5"/>

            <TextView
                android:id="@+id/tvItemNote"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12.5sp"
                android:textColor="@color/ieDarkText"
                android:alpha="0.72"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginStart="5dp"/>
        </LinearLayout>

        <!-- কতদিন আগে -->
        <TextView
            android:id="@+id/tvItemRelative"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11.5sp"
            android:textColor="@color/ieDarkText"
            android:alpha="0.45"
            android:layout_marginTop="4dp"/>

        <!-- সম্পাদনা / মুছুন / আরও -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:id="@+id/btnEdit"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:background="@drawable/ie_pill_edit_bg"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_edit"
                    android:id="@+id/ivEditIcon"
                    app:tint="@color/ieEditBlue"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="সম্পাদনা"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/ieEditBlue"
                    android:layout_marginStart="5dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnDelete"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/ie_pill_delete_bg"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_delete"
                    app:tint="@color/ieExpenseText"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="মুছুন"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/ieExpenseText"
                    android:layout_marginStart="5dp"/>
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/btnMore"
                android:layout_width="40dp"
                android:layout_height="34dp"
                android:text="⋯"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="@color/ieDarkText"
                android:background="@drawable/ie_pill_more_bg"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
