<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="12dp"
    android:layout_marginBottom="6dp" android:gravity="center_vertical"
    android:background="@drawable/bg_card_white"
    android:clickable="true" android:focusable="true"
    android:foreground="?attr/selectableItemBackground">
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvTrashTitle" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="14sp"
            android:textStyle="bold" android:textColor="@color/textPrimary"
            android:maxLines="1" android:ellipsize="end"/>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="3dp">
            <TextView android:id="@+id/tvTrashType" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="11sp"
                android:textColor="@color/textSecondary" android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/tvTrashDate" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="11sp"
                android:textColor="@color/textHint"/>
        </LinearLayout>
    </LinearLayout>
    <TextView android:id="@+id/tvTrashAmount" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textSize="14sp"
        android:textStyle="bold" android:textColor="@color/textSecondary"
        android:layout_marginStart="8dp"/>
</LinearLayout>
