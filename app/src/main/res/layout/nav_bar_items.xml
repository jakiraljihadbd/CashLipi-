<?xml version="1.0" encoding="utf-8"?>
<!-- ৭-আইকন নেভ বার — DashboardActivity রানটাইমে এই ভিউটাকে topNavSlot বা bottomNavSlot-এ বসায়।
     ব্যাকগ্রাউন্ড কালার ও আইকন সাইজ সেটিং অনুযায়ী কোডে সেট করা হয় (bindNavBarStyle)। -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/topNavBar"
    android:layout_width="match_parent"
    android:layout_height="@dimen/top_nav_bar_height"
    android:orientation="horizontal">

    <!-- ১. হোম -->
    <LinearLayout android:id="@+id/navHome" style="@style/TopNavItemStyle">
        <ImageView android:id="@+id/iconNavHome" style="@style/TopNavIconStyle"
            android:src="@drawable/ic_nav_home"/>
        <View android:id="@+id/indicatorNavHome" style="@style/TopNavIndicatorStyle"/>
    </LinearLayout>

    <!-- ২. আয়-ব্যয় -->
    <LinearLayout android:id="@+id/navIncomeExpense" style="@style/TopNavItemStyle">
        <ImageView android:id="@+id/iconNavIncomeExpense" style="@style/TopNavIconStyle"
            android:src="@drawable/ic_nav_income_expense"/>
        <View android:id="@+id/indicatorNavIncomeExpense" style="@style/TopNavIndicatorStyle"/>
    </LinearLayout>

    <!-- ৩. দেনা-পাওনা -->
    <LinearLayout android:id="@+id/navDenaPawna" style="@style/TopNavItemStyle">
        <ImageView android:id="@+id/iconNavDenaPawna" style="@style/TopNavIconStyle"
            android:src="@drawable/ic_nav_dena_pawna"/>
        <View android:id="@+id/indicatorNavDenaPawna" style="@style/TopNavIndicatorStyle"/>
    </LinearLayout>

    <!-- ৪. সঞ্চয় -->
    <LinearLayout android:id="@+id/navSavings" style="@style/TopNavItemStyle">
        <ImageView android:id="@+id/iconNavSavings" style="@style/TopNavIconStyle"
            android:src="@drawable/ic_nav_savings"/>
        <View android:id="@+id/indicatorNavSavings" style="@style/TopNavIndicatorStyle"/>
    </LinearLayout>

    <!-- ৫. বাকির খাতা -->
    <LinearLayout android:id="@+id/navBakirKhata" style="@style/TopNavItemStyle">
        <ImageView android:id="@+id/iconNavBakirKhata" style="@style/TopNavIconStyle"
            android:src="@drawable/ic_nav_bakir_khata"/>
        <View android:id="@+id/indicatorNavBakirKhata" style="@style/TopNavIndicatorStyle"/>
    </LinearLayout>

    <!-- ৬. বাজেট -->
    <LinearLayout android:id="@+id/navBudget" style="@style/TopNavItemStyle">
        <ImageView android:id="@+id/iconNavBudget" style="@style/TopNavIconStyle"
            android:src="@drawable/ic_nav_budget"/>
        <View android:id="@+id/indicatorNavBudget" style="@style/TopNavIndicatorStyle"/>
    </LinearLayout>

    <!-- ৭. সেটিং -->
    <LinearLayout android:id="@+id/navSettings" style="@style/TopNavItemStyle">
        <ImageView android:id="@+id/iconNavSettings" style="@style/TopNavIconStyle"
            android:src="@drawable/ic_nav_settings"/>
        <View android:id="@+id/indicatorNavSettings" style="@style/TopNavIndicatorStyle"/>
    </LinearLayout>
</LinearLayout>
