<?xml version="1.0" encoding="utf-8"?>
<!-- ড্রয়ারের উপরের প্রোফাইল হেডার — বিকাশ পিংক ব্যাকগ্রাউন্ড, গোল ছবি/initials, নাম, Google একাউন্ট -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bkashPink"
    android:paddingHorizontal="20dp"
    android:paddingTop="36dp"
    android:paddingBottom="18dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginBottom="10dp">

        <ImageView
            android:id="@+id/drawerProfilePhoto"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/shape_circle_solid"
            android:backgroundTint="#33FFFFFF"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:contentDescription="প্রোফাইল ছবি"/>

        <TextView
            android:id="@+id/drawerProfileInitials"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/shape_circle_solid"
            android:backgroundTint="#33FFFFFF"
            android:gravity="center"
            android:text="👤"
            android:textSize="22sp" android:textStyle="bold"
            android:textColor="#FFFFFF"/>
    </FrameLayout>

    <TextView
        android:id="@+id/drawerProfileName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ব্যবহারকারী"
        android:textSize="17sp" android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:maxLines="1" android:ellipsize="end"/>

    <TextView
        android:id="@+id/drawerProfileAccount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="সাইন ইন করা নেই"
        android:textSize="12.5sp"
        android:textColor="#E6FFFFFF"
        android:maxLines="1" android:ellipsize="end"/>

</LinearLayout>
