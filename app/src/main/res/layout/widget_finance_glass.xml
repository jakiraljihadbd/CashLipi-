<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_glass_root"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ===== Header: ব্র্যান্ড + রিফ্রেশ ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CashLipi"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.06"
                android:textColor="#FFFFFF"/>

            <ImageView
                android:id="@+id/widgetRefreshBtn"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:padding="4dp"
                android:background="@drawable/bg_widget_refresh_btn"
                android:src="@drawable/ic_widget_refresh"/>
        </LinearLayout>

        <!-- ===== ব্যালেন্স ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="মোট ব্যালেন্স"
            android:textSize="11sp"
            android:textColor="#B9C2D6"/>

        <TextView
            android:id="@+id/widgetBalanceAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:layout_marginBottom="12dp"
            android:text="৳০.০০"
            android:textSize="26sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:textColor="#FFFFFF"/>

        <!-- ===== ২x২ গ্রিড — আয় ব্যয় দেনা-পাওনা সঞ্চয় ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <!-- আয় -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_widget_glass_cell"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="10dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_widget_income"
                        android:layout_marginEnd="8dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="আয়"
                            android:textSize="10sp"
                            android:textColor="#B9C2D6"/>

                        <TextView
                            android:id="@+id/widgetIncomeAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="৳০"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#4ADE80"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- ব্যয় -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_widget_glass_cell"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="10dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_widget_expense"
                        android:layout_marginEnd="8dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ব্যয়"
                            android:textSize="10sp"
                            android:textColor="#B9C2D6"/>

                        <TextView
                            android:id="@+id/widgetExpenseAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="৳০"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#F87171"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <!-- দেনা-পাওনা -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_widget_glass_cell"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="10dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_widget_ledger"
                        android:layout_marginEnd="8dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="দেনা-পাওনা"
                            android:textSize="10sp"
                            android:textColor="#B9C2D6"/>

                        <TextView
                            android:id="@+id/widgetLedgerAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="৳০"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#FBBF24"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- সঞ্চয় -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_widget_glass_cell"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="10dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_widget_savings"
                        android:layout_marginEnd="8dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="সঞ্চয়"
                            android:textSize="10sp"
                            android:textColor="#B9C2D6"/>

                        <TextView
                            android:id="@+id/widgetSavingsAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="৳০"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#C4B5FD"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
