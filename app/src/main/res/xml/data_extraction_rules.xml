<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="."/>
        <!-- Keystore-encrypted App Lock ডাটা ক্লাউড ব্যাকআপে গেলে নতুন ডিভাইসে decrypt করা
             যাবে না (Keystore key ডিভাইস-বাউন্ড, কখনো এক্সপোর্ট হয় না) — তাই বাদ রাখা হলো। -->
        <exclude domain="sharedpref" path="cashlipi_app_lock_secure.xml"/>
        <exclude domain="sharedpref" path="cashlipi_app_lock_secure_fallback.xml"/>
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="."/>
        <exclude domain="sharedpref" path="cashlipi_app_lock_secure.xml"/>
        <exclude domain="sharedpref" path="cashlipi_app_lock_secure_fallback.xml"/>
    </device-transfer>
</data-extraction-rules>
